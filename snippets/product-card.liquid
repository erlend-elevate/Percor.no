{%- comment -%}
  Product card snippet
  Usage: {% render 'product-card', product: product %}
{%- endcomment -%}

<a href="{{ product.url }}" class="product-card" aria-label="{{ product.title }}">
  <div class="product-card__image">
    {%- if product.featured_image -%}
      <img
        src="{{ product.featured_image | image_url: width: 600 }}"
        srcset="
          {{ product.featured_image | image_url: width: 300 }} 300w,
          {{ product.featured_image | image_url: width: 600 }} 600w
        "
        sizes="(max-width: 576px) 50vw, (max-width: 992px) 33vw, 25vw"
        alt="{{ product.featured_image.alt | default: product.title | escape }}"
        width="600"
        height="600"
        loading="lazy"
      >
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}

    {%- if product.available == false -%}
      <span class="product-card__badge badge badge--sale">Utsolgt</span>
    {%- elsif product.compare_at_price > product.price -%}
      <span class="product-card__badge badge badge--sale">Salg</span>
    {%- elsif product.tags contains 'nyhet' -%}
      <span class="product-card__badge badge badge--new">Nyhet</span>
    {%- endif -%}
  </div>

  {%- if product.vendor != blank -%}
    <p class="product-card__vendor">{{ product.vendor }}</p>
  {%- endif -%}

  <h3 class="product-card__title">{{ product.title }}</h3>

  <p class="product-card__price{% if product.compare_at_price > product.price %} product-card__price--sale{% endif %}">
    {%- if product.price_varies -%}
      Fra {{ product.price_min | money }}
    {%- else -%}
      {{ product.price | money }}
    {%- endif -%}
    {%- if product.compare_at_price > product.price -%}
      <s>{{ product.compare_at_price | money }}</s>
    {%- endif -%}
  </p>

  {%- if product.options_by_name['Farge'] and product.options_by_name['Farge'].values.size > 1 -%}
    <div class="product-card__swatches">
      {%- for color in product.options_by_name['Farge'].values limit: 5 -%}
        <span class="product-card__swatch" title="{{ color }}" style="background-color: {{ color | downcase | replace: ' ', '' }};"></span>
      {%- endfor -%}
      {%- if product.options_by_name['Farge'].values.size > 5 -%}
        <span class="product-card__swatch" style="font-size: 0.6rem; display: flex; align-items: center; justify-content: center; width: auto; padding: 0 4px;">+{{ product.options_by_name['Farge'].values.size | minus: 5 }}</span>
      {%- endif -%}
    </div>
  {%- endif -%}
</a>
