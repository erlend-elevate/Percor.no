{%- comment -%}
  Structured data (JSON-LD) for SEO
  Usage: {% render 'structured-data' %}
  Include in theme.liquid or specific templates
{%- endcomment -%}

{%- if template.name == 'index' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Percor AS",
    "url": "https://percor.no",
    "logo": "{{ 'logo.svg' | asset_url | prepend: 'https://percor.no' }}",
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+47-907-72-409",
      "contactType": "customer service",
      "availableLanguage": "Norwegian"
    },
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Åsveien 5",
      "addressLocality": "Sætre",
      "postalCode": "3475",
      "addressCountry": "NO"
    },
    "sameAs": [
      "{{ settings.social_facebook_link }}",
      "{{ settings.social_instagram_link }}"
    ]
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Store",
    "name": "Percor AS",
    "description": "Norsk importør og leverandør av arbeidstøy, profilklær, verneutstyr og tekstiltrykk",
    "url": "https://percor.no",
    "telephone": "+47-907-72-409",
    "email": "stein@percor.no",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Åsveien 5",
      "addressLocality": "Sætre",
      "postalCode": "3475",
      "addressCountry": "NO"
    },
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "08:00",
      "closes": "16:00"
    }
  }
  </script>
{%- endif -%}

{%- if template.name == 'product' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": {{ product.title | json }},
    "brand": {
      "@type": "Brand",
      "name": {{ product.vendor | json }}
    },
    "description": {{ product.description | strip_html | truncatewords: 50 | json }},
    "image": {{ product.featured_image | image_url: width: 1200 | json }},
    "sku": {{ product.selected_or_first_available_variant.sku | json }},
    "offers": {
      "@type": "Offer",
      "priceCurrency": "NOK",
      "price": {{ product.price | money_without_currency | remove: ' ' | json }},
      "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
      "url": "{{ shop.url }}{{ product.url }}",
      "seller": {
        "@type": "Organization",
        "name": "Percor AS"
      }
    }
  }
  </script>
{%- endif -%}

{%- if template.name == 'collection' or template.name == 'product' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Hjem",
        "item": "{{ shop.url }}"
      }
      {%- if template.name == 'collection' -%}
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": {{ collection.title | json }},
          "item": "{{ shop.url }}{{ collection.url }}"
        }
      {%- endif -%}
      {%- if template.name == 'product' -%}
        {%- if product.collections.size > 0 -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ product.collections.first.title | json }},
            "item": "{{ shop.url }}{{ product.collections.first.url }}"
          }
        {%- endif -%}
        ,{
          "@type": "ListItem",
          "position": 3,
          "name": {{ product.title | json }},
          "item": "{{ shop.url }}{{ product.url }}"
        }
      {%- endif -%}
    ]
  }
  </script>
{%- endif -%}
