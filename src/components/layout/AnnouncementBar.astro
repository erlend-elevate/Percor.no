---
const shopUrl = 'https://butikk.percor.no';
---

<div class="bg-[#0f1d2e] text-dark-text text-sm border-b border-white/5">
  <div class="mx-auto max-w-7xl px-4 py-2 flex items-center justify-center gap-4 md:gap-8 flex-wrap text-center">
    <a href="tel:+4790772409" class="hover:text-white transition-colors flex items-center gap-1.5">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
      907 72 409
