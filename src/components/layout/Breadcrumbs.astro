---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Hjem", "item": "https://percor.no" },
    ...items.map((item, i) => ({
      "@type": "ListItem",
      "position": i + 2,
      "name": item.label,
      ...(item.href ? { "item": `https://percor.no${item.href}` } : {}),
    })),
  ],
};
---

<nav aria-label="Brødsmuler" class="text-sm text-text-light py-4">
  <ol class="flex flex-wrap items-center gap-1.5">
    <li><a href="/" class="hover:text-primary transition-colors">Hjem</a></li>
    {items.map((item, i) => (
      <li class="flex items-center gap-1.5">
        <span class="text-border-dark">/</span>
        {item.href && i < items.length - 1 ? (
          <a href={item.href} class="hover:text-primary transition-colors">{item.label}</a>
        ) : (
          <span class="text-text-secondary" aria-current="page">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
