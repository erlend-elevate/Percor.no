---
interface Props {
  value: string;
  suffix?: string;
  duration?: number;
}

const { value, suffix = '', duration = 2000 } = Astro.props;
// Extract numeric part for animation
const numericMatch = value.match(/(\d+)/);
const target = numericMatch ? parseInt(numericMatch[1]) : 0;
const prefix = value.replace(/\d+.*/, '');
const afterNum = value.replace(/.*\d+/, '').replace(suffix, '');
---

<span
  class="animated-counter"
  data-counter-target={target}
  data-counter-duration={duration}
  data-counter-prefix={prefix}
  data-counter-after={afterNum}
  data-counter-suffix={suffix}
>{value}{suffix}</span>

<script>
  const counters = document.querySelectorAll('.animated-counter');

  const counterObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        if (el.dataset.counterDone) return;
        el.dataset.counterDone = 'true';

        const target = parseInt(el.dataset.counterTarget || '0');
        const duration = parseInt(el.dataset.counterDuration || '2000');
        const prefix = el.dataset.counterPrefix || '';
        const after = el.dataset.counterAfter || '';
        const suffix = el.dataset.counterSuffix || '';

        let start = 0;
        const startTime = performance.now();

        function easeOutExpo(t: number): number {
          return t === 1 ? 1 : 1 - Math.pow(2, -10 * t);
        }

        function update(now: number) {
          const elapsed = now - startTime;
          const progress = Math.min(elapsed / duration, 1);
          const easedProgress = easeOutExpo(progress);
          const current = Math.round(easedProgress * target);

          el.textContent = `${prefix}${current}${after}${suffix}`;

          if (progress < 1) {
            requestAnimationFrame(update);
          }
        }

        requestAnimationFrame(update);
      });
    },
    { threshold: 0.5 }
  );

  counters.forEach((el) => counterObserver.observe(el));
</script>
