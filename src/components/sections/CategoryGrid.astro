---
import SectionHeading from '../ui/SectionHeading.astro';

const categories = [
  { title: 'Tekstiltrykk', desc: 'Broderi, screentrykk, DTF, transfer, sublimering', href: '/tjenester/tekstiltrykk', icon: '👕' },
  { title: 'Foliering', desc: 'Bil, lastebil, butikkvindu, kontordekor', href: '/tjenester/foliering', icon: '🚗' },
  { title: 'Storformat', desc: 'Bannere, rollups, plakater, klistremerker', href: '/tjenester/storformat', icon: '🖼️' },
  { title: 'Grafisk design', desc: 'Logo, profilhåndbok, trykkfiler', href: '/tjenester/grafisk-design', icon: '🎨' },
];
---

<section class="py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-4 lg:px-6">
    <SectionHeading subtitle="Tjenester">
      Hva kan vi hjelpe deg med?
    </SectionHeading>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {categories.map(cat => (
        <a href={cat.href} class="group bg-white rounded-xl border border-border p-6 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200">
          <span class="text-3xl block mb-4">{cat.icon}</span>
          <h3 class="text-lg font-bold text-text group-hover:text-primary transition-colors">{cat.title}</h3>
          <p class="text-sm text-text-secondary mt-2 leading-relaxed">{cat.desc}</p>
          <span class="inline-flex items-center gap-1 mt-4 text-sm font-semibold text-primary">
            Les mer
            <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
