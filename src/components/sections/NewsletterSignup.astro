---
---

<section class="py-16 md:py-20 bg-bg-alt">
  <div class="mx-auto max-w-2xl px-4 lg:px-6 text-center">
    <h2 class="text-2xl md:text-3xl font-bold text-text mb-3">Hold deg oppdatert</h2>
    <p class="text-text-secondary mb-8">Meld deg på nyhetsbrevet for tilbud, nyheter og inspirasjon.</p>
    <form name="nyhetsbrev" method="POST" data-netlify="true" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
      <input type="hidden" name="form-name" value="nyhetsbrev" />
      <input
        type="email"
        name="email"
        required
        placeholder="Din e-postadresse"
        class="flex-1 px-4 py-3 border border-border rounded-lg focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors bg-white"
      />
      <button type="submit" class="bg-primary text-white px-6 py-3 rounded-lg font-semibold hover:bg-primary-light transition-colors whitespace-nowrap">
        Meld på
      </button>
    </form>
    <p class="text-xs text-text-light mt-3">Vi respekterer ditt personvern. Les vår <a href="/personvern" class="underline hover:text-primary">personvernerklæring</a>.</p>
  </div>
</section>
