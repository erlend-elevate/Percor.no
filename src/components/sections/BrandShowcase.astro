---
const brands = [
  { name: 'Payper', country: 'Italia', role: 'Arbeidstøy & profilklær', href: '/merkevarer/payper', exclusive: true, initial: 'P' },
  { name: 'L.Brador', country: 'Sverige', role: 'Arbeidstøy', href: '/merkevarer/l-brador', initial: 'L' },
  { name: 'Roly', country: 'Spania', role: 'Profilklær', href: '/merkevarer/roly', initial: 'R' },
  { name: 'Zeus Sport', country: 'Italia', role: 'Sportsutstyr', href: '/merkevarer/zeus-sport', initial: 'Z' },
  { name: 'Skydda', country: 'Sverige', role: 'Verneutstyr', href: '/merkevarer/skydda', initial: 'S' },
  { name: 'Stamina', country: 'Spania', role: 'Profilklær', href: '/merkevarer/stamina', initial: 'S' },
];
---

<section class="py-20 md:py-28">
  <div class="mx-auto max-w-7xl px-4 lg:px-6">
    <div class="text-center mb-14">
      <p data-reveal class="text-accent font-semibold text-sm uppercase tracking-widest mb-4">Merkevarer</p>
      <h2 data-reveal class="text-3xl md:text-4xl font-extrabold text-text">
        Nøye utvalgt. Grundig testet.
      </h2>
      <p data-reveal class="mt-4 text-text-secondary max-w-xl mx-auto">
        Vi fører bare merkevarer vi selv står inne for. Hver leverandør er valgt fordi de leverer kvalitet — gang etter gang.
      </p>
    </div>

    <div data-reveal-stagger class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
      {brands.map((brand) => (
        <a href={brand.href} class={`group relative bg-white rounded-2xl border p-6 text-center hover:shadow-lg hover:-translate-y-1 transition-all duration-200 ${brand.exclusive ? 'border-accent/30 ring-1 ring-accent/10' : 'border-border'}`}>
          {brand.exclusive && (
            <span class="absolute -top-2.5 left-1/2 -translate-x-1/2 bg-accent text-white text-[10px] font-bold px-2.5 py-0.5 rounded-full uppercase tracking-wider whitespace-nowrap">Eksklusiv</span>
          )}
          <div class={`w-12 h-12 mx-auto rounded-xl flex items-center justify-center mb-3 ${brand.exclusive ? 'bg-accent/10' : 'bg-primary/5'}`}>
            <span class={`text-xl font-extrabold ${brand.exclusive ? 'text-accent' : 'text-primary'}`}>{brand.initial}</span>
          </div>
          <h3 class="font-bold text-text group-hover:text-primary transition-colors text-sm">{brand.name}</h3>
          <p class="text-[11px] text-text-light mt-1">{brand.country} · {brand.role}</p>
        </a>
      ))}
    </div>

    <div data-reveal class="text-center mt-10">
      <a href="/merkevarer" class="group inline-flex items-center gap-2 text-sm font-semibold text-primary hover:text-primary-light transition-colors">
        Se alle merkevarer
        <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>
