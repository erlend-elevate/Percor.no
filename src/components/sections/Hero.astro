---
import AnimatedCounter from '../AnimatedCounter.astro';
const shopUrl = 'https://butikk.percor.no';
---

<section class="relative bg-primary min-h-[90vh] flex items-center overflow-hidden">
  <!-- Layered background -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-gradient-to-br from-[#0f1d2e] via-primary to-primary-light/80"></div>
    <!-- Animated grid -->
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;40&quot; height=&quot;40&quot; viewBox=&quot;0 0 40 40&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; stroke=&quot;%23ffffff&quot; stroke-width=&quot;0.5&quot;%3E%3Cpath d=&quot;M0 20h40M20 0v40&quot;/%3E%3C/g%3E%3C/svg%3E'); background-size: 40px 40px;"></div>
    <!-- Gradient orbs -->
    <div class="absolute top-1/4 right-1/4 w-[500px] h-[500px] bg-accent/8 rounded-full blur-[120px] animate-float"></div>
    <div class="absolute bottom-1/3 left-1/6 w-[300px] h-[300px] bg-primary-lighter/15 rounded-full blur-[100px] animate-float-delayed"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 lg:px-6 py-20 md:py-28 lg:py-36 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
      <!-- Left: narrative hook (7 cols) -->
      <div class="lg:col-span-7">
        <div data-reveal class="inline-flex items-center gap-2.5 bg-white/[0.07] backdrop-blur-md rounded-full px-5 py-2 mb-8 border border-white/10">
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent-light opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-accent-light"></span>
          </span>
          <span class="text-white/80 text-sm font-medium">Eksklusiv Payper-importør i Norge</span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl xl:text-[4.2rem] font-extrabold text-white leading-[1.08] tracking-tight">
          <span class="text-reveal-mask" data-reveal="fade"><span>Vi kler opp</span></span><br />
          <span class="text-reveal-mask" data-reveal="fade"><span class="gradient-text">bedriften din.</span></span><br />
          <span class="text-reveal-mask" data-reveal="fade"><span>Fra topp til tå.</span></span>
        </h1>

        <p data-reveal class="mt-8 text-lg md:text-xl text-white/60 leading-relaxed max-w-xl">
          Arbeidstøy, profilklær, trykk, foliering og design. Én leverandør — fra idé til ferdig resultat.
        </p>

        <div data-reveal class="mt-10 flex flex-wrap gap-4">
          <a href="/kontakt" class="group relative inline-flex items-center gap-2 bg-accent text-white px-8 py-4 rounded-xl font-semibold hover:bg-accent-light transition-all text-base shadow-lg shadow-accent/25 overflow-hidden">
            <span class="relative z-10 flex items-center gap-2">
              Fortell oss hva du trenger
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
            <div class="absolute inset-0 shimmer"></div>
          </a>
          <a href={shopUrl} target="_blank" rel="noopener" class="group inline-flex items-center gap-2 bg-white/[0.06] text-white px-8 py-4 rounded-xl font-semibold hover:bg-white/[0.12] transition-all text-base backdrop-blur-sm border border-white/10">
            Nettbutikken
            <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
          </a>
        </div>

        <!-- Trust signals -->
        <div data-reveal class="mt-12 flex items-center gap-6 text-white/30 text-sm">
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Norsk lager
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Ingen minimumsordre
          </span>
          <span class="hidden md:flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Gratis prøvetrykk
          </span>
        </div>
      </div>

      <!-- Right: animated proof panel (5 cols) -->
      <div class="lg:col-span-5 hidden lg:block" data-reveal="right">
        <div class="relative" data-depth="0.05">
          <!-- Main stats card -->
          <div class="bg-white/[0.05] backdrop-blur-xl rounded-3xl border border-white/10 p-8 glow-accent">
            <div class="flex items-center gap-3 mb-8">
              <div class="w-10 h-10 rounded-xl bg-accent/20 flex items-center justify-center">
                <svg class="w-5 h-5 text-accent-light" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              </div>
              <div>
                <p class="text-white text-sm font-semibold">Percor i tall</p>
                <p class="text-white/40 text-xs">Oppdatert 2026</p>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div class="bg-white/[0.04] rounded-2xl p-5 text-center border border-white/5 hover:border-accent/20 transition-colors">
                <p class="text-3xl font-extrabold text-white"><AnimatedCounter value="500" suffix="+" /></p>
                <p class="text-[11px] text-white/40 mt-2 uppercase tracking-wider">Produkter</p>
              </div>
              <div class="bg-white/[0.04] rounded-2xl p-5 text-center border border-white/5 hover:border-accent/20 transition-colors">
                <p class="text-3xl font-extrabold text-accent-light"><AnimatedCounter value="6" /></p>
                <p class="text-[11px] text-white/40 mt-2 uppercase tracking-wider">Merkevarer</p>
              </div>
              <div class="bg-white/[0.04] rounded-2xl p-5 text-center border border-white/5 hover:border-accent/20 transition-colors">
                <p class="text-3xl font-extrabold text-white"><AnimatedCounter value="5" /></p>
                <p class="text-[11px] text-white/40 mt-2 uppercase tracking-wider">Trykkteknikker</p>
              </div>
              <div class="bg-white/[0.04] rounded-2xl p-5 text-center border border-white/5 hover:border-accent/20 transition-colors">
                <p class="text-3xl font-extrabold text-accent-light"><AnimatedCounter value="2-3" suffix=" uker" /></p>
                <p class="text-[11px] text-white/40 mt-2 uppercase tracking-wider">Leveringstid</p>
              </div>
            </div>
          </div>

          <!-- Floating accent cards -->
          <div class="absolute -bottom-6 -left-6 bg-accent text-white rounded-2xl px-5 py-3 shadow-xl shadow-accent/30 animate-float-delayed">
            <p class="text-sm font-bold flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              Sætre, Hurum
            </p>
          </div>

          <div class="absolute -top-4 -right-4 bg-white rounded-2xl px-5 py-3 shadow-xl animate-float border border-border">
            <p class="text-xs font-bold text-primary flex items-center gap-1.5">
              <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              Betrodd leverandør
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
    <span class="text-[10px] text-white/30 tracking-[0.3em] uppercase">Utforsk</span>
    <svg class="w-5 h-5 text-white/20 animate-bounce" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
  </div>
</section>
