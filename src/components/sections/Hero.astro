---
const shopUrl = 'https://butikk.percor.no';
---

<section class="relative bg-primary min-h-[85vh] flex items-center overflow-hidden">
  <!-- Animated background pattern -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary to-primary-light opacity-90"></div>
    <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-accent/5 to-transparent"></div>
    <!-- Subtle grid pattern -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; stroke=&quot;%23ffffff&quot; stroke-width=&quot;1&quot;%3E%3Cpath d=&quot;M0 30h60M30 0v60&quot;/%3E%3C/g%3E%3C/svg%3E'); background-size: 60px 60px;"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 lg:px-6 py-20 md:py-28 lg:py-36 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: story hook -->
      <div>
        <div data-reveal class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm rounded-full px-4 py-1.5 mb-6">
          <span class="w-2 h-2 bg-accent-light rounded-full animate-pulse"></span>
          <span class="text-accent-light text-sm font-medium">Eksklusiv norsk Payper-importør</span>
        </div>

        <h1 data-reveal class="text-4xl md:text-5xl lg:text-[3.5rem] font-extrabold text-white leading-[1.1] tracking-tight">
          Vi kler opp<br />
          <span class="text-accent-light">bedriften din.</span><br />
          Fra topp til tå.
        </h1>

        <p data-reveal class="mt-6 text-lg md:text-xl text-dark-text-secondary leading-relaxed max-w-lg">
          Arbeidstøy. Profilklær. Trykk. Foliering. Design. Alt fra én leverandør som kjenner deg og behovene dine.
        </p>

        <div data-reveal class="mt-8 flex flex-wrap gap-4">
          <a href="/kontakt" class="group inline-flex items-center gap-2 bg-accent text-white px-7 py-4 rounded-xl font-semibold hover:bg-accent-light transition-all text-base shadow-lg shadow-accent/20">
            Fortell oss hva du trenger
            <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href={shopUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-white/10 text-white px-7 py-4 rounded-xl font-semibold hover:bg-white/20 transition-all text-base backdrop-blur-sm border border-white/10">
            Nettbutikken
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
          </a>
        </div>
      </div>

      <!-- Right: visual proof / stats -->
      <div data-reveal="right" class="hidden lg:block">
        <div class="relative">
          <!-- Stats card cluster -->
          <div class="bg-white/[0.07] backdrop-blur-md rounded-2xl border border-white/10 p-8">
            <p class="text-white/60 text-sm font-medium uppercase tracking-wider mb-6">Derfor velger bedrifter oss</p>
            <div class="grid grid-cols-2 gap-6">
              <div class="text-center p-4 bg-white/5 rounded-xl">
                <p class="text-3xl font-extrabold text-white">500+</p>
                <p class="text-sm text-white/50 mt-1">Produkter på lager</p>
              </div>
              <div class="text-center p-4 bg-white/5 rounded-xl">
                <p class="text-3xl font-extrabold text-accent-light">6</p>
                <p class="text-sm text-white/50 mt-1">Ledende merkevarer</p>
              </div>
              <div class="text-center p-4 bg-white/5 rounded-xl">
                <p class="text-3xl font-extrabold text-white">5</p>
                <p class="text-sm text-white/50 mt-1">Trykkteknikker</p>
              </div>
              <div class="text-center p-4 bg-white/5 rounded-xl">
                <p class="text-3xl font-extrabold text-accent-light">2–3</p>
                <p class="text-sm text-white/50 mt-1">Ukers leveringstid</p>
              </div>
            </div>
          </div>

          <!-- Floating accent card -->
          <div class="absolute -bottom-4 -left-4 bg-accent text-white rounded-xl px-5 py-3 shadow-xl shadow-accent/30">
            <p class="text-sm font-bold">Norsk lager & support</p>
            <p class="text-xs text-white/80">Sætre, Hurum</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/40 flex flex-col items-center gap-2">
      <span class="text-xs tracking-widest uppercase">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-white/40 to-transparent animate-pulse"></div>
    </div>
  </div>
</section>
