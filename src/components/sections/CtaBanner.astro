---
const shopUrl = 'https://butikk.percor.no';
---

<section class="relative py-24 md:py-32 bg-primary overflow-hidden">
  <!-- Decorative -->
  <div class="absolute inset-0">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-accent/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-64 h-64 bg-primary-lighter/20 rounded-full blur-3xl"></div>
  </div>

  <div class="relative mx-auto max-w-3xl px-4 lg:px-6 text-center">
    <h2 data-reveal class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-white leading-tight">
      Klar for å gi bedriften<br />din et ansikt utad?
    </h2>
    <p data-reveal class="mt-6 text-lg text-dark-text-secondary max-w-xl mx-auto">
      Fortell oss hva du trenger. Vi svarer innen én arbeidsdag med et forslag skreddersydd for deg.
    </p>
    <div data-reveal class="mt-10 flex flex-wrap justify-center gap-4">
      <a href="/kontakt" class="group inline-flex items-center gap-2 bg-accent text-white px-8 py-4 rounded-xl font-semibold hover:bg-accent-light transition-all text-lg shadow-lg shadow-accent/30">
        Be om tilbud
        <svg class="w-5 h-5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="tel:+4790772409" class="inline-flex items-center gap-2 bg-white/10 text-white px-8 py-4 rounded-xl font-semibold hover:bg-white/20 transition-all text-lg backdrop-blur-sm border border-white/10">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
        Ring oss
      </a>
    </div>
    <p data-reveal class="mt-6 text-sm text-white/40">
      Eller besøk <a href={shopUrl} target="_blank" rel="noopener" class="underline text-white/60 hover:text-white transition-colors">nettbutikken</a> for å handle direkte
    </p>
  </div>
</section>
