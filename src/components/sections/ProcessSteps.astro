---
import SectionHeading from '../ui/SectionHeading.astro';

const steps = [
  { num: '01', title: 'Kontakt oss', desc: 'Send oss en forespørsel med dine ønsker og behov.' },
  { num: '02', title: 'Tilbud & design', desc: 'Vi lager et tilpasset tilbud og designforslag.' },
  { num: '03', title: 'Godkjenning', desc: 'Du godkjenner prøvetrykk og endelig design.' },
  { num: '04', title: 'Levering', desc: 'Vi produserer og leverer direkte til deg.' },
];
---

<section class="py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-4 lg:px-6">
    <SectionHeading subtitle="Slik jobber vi">
      Fra ide til ferdig produkt
    </SectionHeading>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {steps.map((step, i) => (
        <div class="relative text-center">
          {i < steps.length - 1 && (
            <div class="hidden lg:block absolute top-8 left-[calc(50%+2rem)] w-[calc(100%-4rem)] h-px bg-border"></div>
          )}
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-primary text-white text-xl font-bold mb-4">
            {step.num}
          </div>
          <h3 class="font-bold text-text text-lg">{step.title}</h3>
          <p class="text-sm text-text-secondary mt-2 leading-relaxed">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
