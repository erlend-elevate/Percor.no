---
const usps = [
  { icon: '🇳🇴', title: 'Norsk importør', desc: 'Direkte fra produsent' },
  { icon: '🎨', title: 'Eget designteam', desc: 'Logo, profil & trykk' },
  { icon: '🚚', title: 'Rask levering', desc: 'Hele Norge' },
  { icon: '🤝', title: 'Personlig service', desc: 'Alltid tilgjengelig' },
];
---

<section class="bg-bg-alt border-y border-border">
  <div class="mx-auto max-w-7xl px-4 lg:px-6 py-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {usps.map(usp => (
        <div class="flex items-center gap-3">
          <span class="text-2xl flex-shrink-0">{usp.icon}</span>
          <div>
            <p class="font-semibold text-text text-sm">{usp.title}</p>
            <p class="text-xs text-text-secondary">{usp.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
