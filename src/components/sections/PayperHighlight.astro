---
const shopUrl = 'https://butikk.percor.no';
---

<section class="py-16 md:py-24 bg-primary">
  <div class="mx-auto max-w-7xl px-4 lg:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-accent-light font-semibold text-sm uppercase tracking-wider mb-3">Eksklusiv norsk forhandler</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Payper — Italiensk kvalitet<br />for norske arbeidsfolk
        </h2>
        <p class="text-dark-text-secondary leading-relaxed mb-4">
          Percor er stolt eksklusiv importør og distributør av Payper i Norge. Med over 40 års erfaring leverer Payper arbeidstøy og profilklær som kombinerer italiensk design med funksjonalitet og holdbarhet.
        </p>
        <ul class="space-y-2 text-dark-text-secondary mb-8">
          <li class="flex items-center gap-2">
            <svg class="w-5 h-5 text-accent-light flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
            Bredt sortiment — fra t-skjorter til high-vis
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-5 h-5 text-accent-light flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
            Konkurransedyktige priser — direkte fra produsent
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-5 h-5 text-accent-light flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
            Raske leveranser fra norsk lager
          </li>
        </ul>
        <div class="flex flex-wrap gap-4">
          <a href="/merkevarer/payper" class="inline-flex items-center gap-2 bg-accent text-white px-6 py-3 rounded-lg font-semibold hover:bg-accent-light transition-colors">
            Utforsk Payper
          </a>
          <a href={shopUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-white/10 text-white px-6 py-3 rounded-lg font-semibold hover:bg-white/20 transition-colors backdrop-blur-sm">
            Handle i nettbutikken
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
          </a>
        </div>
      </div>
      <div class="bg-white/5 rounded-2xl p-8 lg:p-12 backdrop-blur-sm border border-white/10">
        <div class="text-center">
          <span class="text-6xl mb-4 block">🇮🇹</span>
          <h3 class="text-2xl font-bold text-white mb-2">Payper</h3>
          <p class="text-dark-text-secondary text-sm mb-6">Made in Italy — Since 1977</p>
          <div class="grid grid-cols-2 gap-4 text-center">
            <div class="bg-white/5 rounded-lg p-4">
              <p class="text-2xl font-bold text-accent-light">500+</p>
              <p class="text-xs text-dark-text-secondary mt-1">Produkter</p>
            </div>
            <div class="bg-white/5 rounded-lg p-4">
              <p class="text-2xl font-bold text-accent-light">40+</p>
              <p class="text-xs text-dark-text-secondary mt-1">År erfaring</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
