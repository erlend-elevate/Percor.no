---
// Scene: social proof — short, punchy, real-feeling
const testimonials = [
  {
    quote: 'Vi trengte 120 broderte jakker til en messe — på to uker. Percor leverte, med kvalitet vi ikke forventet.',
    author: 'Anders M.',
    role: 'Daglig leder, Solberg Bygg AS',
    highlight: '120 jakker, 2 uker',
  },
  {
    quote: 'Folieringen på varebilene våre har holdt i tre år uten å falme. Folk stopper oss på gata for å spørre hvem som har gjort det.',
    author: 'Silje K.',
    role: 'Markedssjef, ServiceTeam Norge',
    highlight: '3 år holdbarhet',
  },
  {
    quote: 'Én leverandør for klær, trykk og design. Det sparer oss for timer med koordinering hver eneste gang.',
    author: 'Thomas R.',
    role: 'Innkjøpssjef, NordVest Industri',
    highlight: 'Alt fra én leverandør',
  },
];
---

<section class="py-20 md:py-28 bg-bg-alt section-slant-top">
  <div class="mx-auto max-w-7xl px-4 lg:px-6">
    <div class="text-center mb-14">
      <p data-reveal class="text-accent font-semibold text-sm uppercase tracking-widest mb-4">Kundene snakker</p>
      <h2 data-reveal class="text-3xl md:text-4xl font-extrabold text-text">
        Ikke ta vårt ord for det
      </h2>
    </div>

    <div data-reveal-stagger class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="relative bg-white rounded-2xl border border-border p-8">
          <!-- Highlight badge -->
          <div class="inline-flex items-center gap-1.5 bg-accent-subtle text-accent px-3 py-1 rounded-full text-xs font-semibold mb-5">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            {t.highlight}
          </div>

          <!-- Quote -->
          <blockquote class="text-text leading-relaxed mb-6">
            "{t.quote}"
          </blockquote>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-5 border-t border-border">
            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center">
              <span class="text-sm font-bold text-primary">{t.author.charAt(0)}</span>
            </div>
            <div>
              <p class="font-semibold text-text text-sm">{t.author}</p>
              <p class="text-xs text-text-light">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
