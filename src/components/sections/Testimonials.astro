---
import SectionHeading from '../ui/SectionHeading.astro';

const testimonials = [
  {
    quote: 'Percor leverte profilklær og trykk til hele teamet vårt. Fantastisk kvalitet og rask levering!',
    author: 'Anders M.',
    role: 'Daglig leder, Bygg & Anlegg AS',
  },
  {
    quote: 'Vi har brukt Percor til foliering av bilene våre i flere år. Alltid profesjonelt og pent resultat.',
    author: 'Silje K.',
    role: 'Markedssjef, ServiceTeam Norge',
  },
  {
    quote: 'Strålende service fra bestilling til levering. Designhjelpen var uvurderlig for vår nye profil.',
    author: 'Thomas R.',
    role: 'Grunder, TR Solutions',
  },
];
---

<section class="py-16 md:py-24 bg-bg-alt">
  <div class="mx-auto max-w-7xl px-4 lg:px-6">
    <SectionHeading subtitle="Kundeomtaler">
      Hva kundene sier
    </SectionHeading>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map(t => (
        <div class="bg-white rounded-xl border border-border p-6">
          <div class="flex gap-1 mb-4">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <p class="text-text-secondary leading-relaxed mb-4 italic">"{t.quote}"</p>
          <div>
            <p class="font-semibold text-text text-sm">{t.author}</p>
            <p class="text-xs text-text-light">{t.role}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
