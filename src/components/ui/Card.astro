---
interface Props {
  href?: string;
  class?: string;
  hoverable?: boolean;
}

const { href, class: className = '', hoverable = true } = Astro.props;
const base = `bg-white rounded-xl border border-border overflow-hidden ${hoverable ? 'hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200' : ''} ${className}`;
---

{href ? (
  <a href={href} class={`block ${base}`}>
    <slot />
  </a>
) : (
  <div class={base}>
    <slot />
  </div>
)}
