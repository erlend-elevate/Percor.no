---
interface Props {
  subtitle?: string;
  align?: 'left' | 'center';
  class?: string;
}

const { subtitle, align = 'center', class: className = '' } = Astro.props;
const alignment = align === 'center' ? 'text-center mx-auto' : '';
---

<div class={`max-w-2xl mb-12 ${alignment} ${className}`}>
  {subtitle && <p class="text-sm font-semibold text-accent uppercase tracking-wider mb-2">{subtitle}</p>}
  <h2 class="text-3xl md:text-4xl font-bold text-text">
    <slot />
  </h2>
  <slot name="description" />
</div>
