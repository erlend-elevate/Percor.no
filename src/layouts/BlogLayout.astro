---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  author?: string;
}

const { title, description, date, author = 'Percor-teamet' } = Astro.props;
const formattedDate = new Date(date).toLocaleDateString('nb-NO', { day: 'numeric', month: 'long', year: 'numeric' });
---

<BaseLayout title={title} description={description}>
  <div class="mx-auto max-w-7xl px-4 lg:px-6">
    <Breadcrumbs items={[{label: 'Blogg', href: '/blogg'}, {label: title}]} />
  </div>
  <article class="mx-auto max-w-3xl px-4 lg:px-6 pb-16">
    <header class="mb-8">
      <time class="text-sm text-text-light">{formattedDate}</time>
      <h1 class="text-3xl md:text-4xl font-bold text-text mt-2 leading-tight">{title}</h1>
      <p class="text-text-secondary mt-2">Av {author}</p>
    </header>
    <div class="prose prose-lg max-w-none">
      <slot />
    </div>
    <div class="mt-12 pt-8 border-t border-border text-center">
      <p class="text-text-secondary mb-4">Har du spørsmål om dette temaet?</p>
      <a href="/kontakt" class="inline-flex items-center gap-2 bg-primary text-white px-6 py-3 rounded-lg font-semibold hover:bg-primary-light transition-colors">Kontakt oss</a>
    </div>
  </article>
</BaseLayout>
