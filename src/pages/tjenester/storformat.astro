---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';

const useCases = [
  {
    title: 'Messe & event',
    desc: 'Du har sekunder på deg til å fange oppmerksomheten til forbipasserende. Rollups, bannere og veggdekor som skiller deg fra mengden, gjor at standen din blir den folk husker.',
    details: 'Rollups, bannere, veggdekor',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18M7 16V9m4 7v-4m4 4V6m4 10V3"/></svg>`,
  },
  {
    title: 'Butikk & fasade',
    desc: 'Fasaden er ditt forste inntrykk. Riktig skilting og vindusdekor forteller kundene hvem du er for de engang tar steget inn. Fra kampanjeplakater til permanente fasadeskilt.',
    details: 'Skilt, vindusdekor, plakater',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 0 0 3.75-.615A2.993 2.993 0 0 0 9.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 0 0 2.25 1.016c.896 0 1.7-.393 2.25-1.015a3.001 3.001 0 0 0 3.75.614m-16.5 0a3.004 3.004 0 0 1-.621-4.72l1.189-1.19A1.5 1.5 0 0 1 5.378 3h13.243a1.5 1.5 0 0 1 1.06.44l1.19 1.189a3 3 0 0 1-.621 4.72M6.75 18h3.75a.75.75 0 0 0 .75-.75V13.5a.75.75 0 0 0-.75-.75H6.75a.75.75 0 0 0-.75.75v3.75c0 .414.336.75.75.75Z"/></svg>`,
  },
  {
    title: 'Kontor & industri',
    desc: 'Profesjonelle omgivelser krever profesjonell kommunikasjon. Informasjonsskilt som veileder besokende, sikkerhetsskilt som beskytter ansatte, og vegggrafikk som styrker merkevaren innenfra.',
    details: 'Informasjonsskilt, sikkerhetsskilt',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"/></svg>`,
  },
];

const products = [
  {
    title: 'Bannere',
    desc: 'PVC, mesh eller stoff. Til oppheng ute eller inne, med oyer, lommer eller borrelassystem. Storrelsen bestemmer du.',
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3v1.5M3 21v-6m0 0 2.77-.693a9 9 0 0 1 6.208.682l.108.054a9 9 0 0 0 6.086.71l3.114-.732a48.524 48.524 0 0 1-.005-10.499l-3.11.732a9 9 0 0 1-6.085-.711l-.108-.054a9 9 0 0 0-6.208-.682L3 4.5M3 15V4.5"/></svg>`,
  },
  {
    title: 'Rollups',
    desc: 'Fra budsjettmodeller til premium kassetter. Baeresystem inkludert, enkelt a sette opp og ta ned. Ideelt for gjenbruk pa flere arrangementer.',
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 4.5v15m6-15v15m-10.875 0h15.75c.621 0 1.125-.504 1.125-1.125V5.625c0-.621-.504-1.125-1.125-1.125H4.125C3.504 4.5 3 5.004 3 5.625v12.75c0 .621.504 1.125 1.125 1.125Z"/></svg>`,
  },
  {
    title: 'Plakater',
    desc: 'Innendors pa premiumpapir, utendors pa vaerbestandig syntetisk materiale. Fra A3 til skreddersydde storformater.',
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5a1.5 1.5 0 0 0 1.5-1.5V4.5a1.5 1.5 0 0 0-1.5-1.5H3.75a1.5 1.5 0 0 0-1.5 1.5v15a1.5 1.5 0 0 0 1.5 1.5Z"/></svg>`,
  },
  {
    title: 'Klistremerker',
    desc: 'Enhver form, enhver storrelse. Stanset, trykt og levert klart til bruk. Fra sma produktetiketter til store gulv- og veggklistremerker.',
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6Z"/></svg>`,
  },
  {
    title: 'Fasadeskilt',
    desc: 'Solide skilt for utendors bruk. Med eller uten belysning, i aluminium, akryl eller dibond. Designet for a tale ar med vaer og vind.',
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0 0 12 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75Z"/></svg>`,
  },
];
---

<BaseLayout
  title="Storformat"
  description="Storformatprint fra Percor — bannere, rollups, plakater, klistremerker og fasadeskilt. Stort nok til a bli lagt merke til."
>
  <Breadcrumbs items={[{ label: 'Tjenester', href: '/tjenester' }, { label: 'Storformat' }]} />

  <!-- Hero -->
  <section class="relative bg-primary overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-gradient-to-br from-primary-light/20 to-transparent"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 lg:px-6 py-20 md:py-32">
      <p data-reveal class="text-accent-light font-semibold text-sm uppercase tracking-wider mb-6">Storformatprint</p>
      <h1 data-reveal class="text-4xl md:text-6xl font-extrabold text-white max-w-3xl leading-tight">
        Stort nok til å bli lagt merke til.
      </h1>
      <p data-reveal class="mt-6 text-lg md:text-xl text-dark-text-secondary max-w-2xl leading-relaxed">
        Noen budskap fortjener mer plass. Enten det handler om å stoppe trafikken på en messe, prege en fasade eller fylle et helt rom med merkevaren din — storformat gjor at du blir sett. Ikke bare registrert, men husket.
      </p>
    </div>
  </section>

  <!-- Use Cases: Hvor trenger du det? -->
  <section class="py-20 md:py-32 bg-bg-alt">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="text-center mb-16" data-reveal>
        <h2 class="text-3xl md:text-4xl font-extrabold text-text mb-4">Hvor trenger du det?</h2>
        <p class="text-text-secondary text-lg max-w-2xl mx-auto">
          Storformat har sin plass overalt der synlighet betyr noe. Her er de vanligste scenariene vi hjelper kunder med.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-reveal-stagger>
        {useCases.map((uc) => (
          <div class="card-3d-inner bg-white rounded-2xl border border-border p-8 flex flex-col">
            <div class="w-14 h-14 rounded-2xl bg-primary-light flex items-center justify-center text-primary mb-6">
              <Fragment set:html={uc.icon} />
            </div>
            <h3 class="text-xl font-extrabold text-text mb-3">{uc.title}</h3>
            <p class="text-text-secondary leading-relaxed mb-4 flex-1">{uc.desc}</p>
            <p class="text-sm font-semibold text-primary">{uc.details}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Products: Hva vi produserer -->
  <section class="py-20 md:py-32">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="max-w-2xl mb-16" data-reveal="left">
        <h2 class="text-3xl md:text-4xl font-extrabold text-text mb-4">Alt du trenger i storformat</h2>
        <p class="text-text-secondary text-lg leading-relaxed">
          Vi produserer alt fra enkle rollups til store fasadeskilt. Hvert produkt tilpasses dine behov — materialvalg, storrelse og finish.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" data-reveal-stagger>
        {products.map((p) => (
          <div class="group bg-white rounded-2xl border border-border p-6 hover:border-accent hover:shadow-lg transition-all duration-300">
            <div class="w-12 h-12 rounded-xl bg-accent-light flex items-center justify-center text-accent mb-5 group-hover:scale-110 transition-transform duration-300">
              <Fragment set:html={p.icon} />
            </div>
            <h3 class="text-lg font-extrabold text-text mb-2">{p.title}</h3>
            <p class="text-text-secondary text-sm leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quality Promise -->
  <section class="py-20 md:py-32 bg-bg-alt">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div data-reveal="left">
          <h2 class="text-3xl md:text-4xl font-extrabold text-text mb-6">Kvalitet som taler varigheten</h2>
          <p class="text-text-secondary text-lg leading-relaxed mb-6">
            Det er ingen vits i a ga stort hvis resultatet blekner etter forste regnskur. Derfor bruker vi kun UV-bestandig blekk som bevarer fargene ar etter ar, og materialer som taler det norske klimaet.
          </p>
          <p class="text-text-secondary text-lg leading-relaxed">
            Vaerbestandige bannere, solide skiltmaterialer i aluminium og akryl, og tekstiler som holder formen — alt skreddersydd for a sta seg over tid, bade inne og ute.
          </p>
        </div>
        <div data-reveal="right" class="grid grid-cols-2 gap-4">
          <div class="bg-white rounded-2xl border border-border p-6 text-center">
            <div class="w-12 h-12 rounded-xl bg-primary-light flex items-center justify-center text-primary mx-auto mb-4">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
            </div>
            <p class="font-extrabold text-text text-sm">UV-bestandig blekk</p>
          </div>
          <div class="bg-white rounded-2xl border border-border p-6 text-center">
            <div class="w-12 h-12 rounded-xl bg-primary-light flex items-center justify-center text-primary mx-auto mb-4">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 0 0 4.5 4.5H18a3.75 3.75 0 0 0 1.332-7.257 3 3 0 0 0-3.758-3.848 5.25 5.25 0 0 0-10.233 2.33A4.502 4.502 0 0 0 2.25 15Z"/></svg>
            </div>
            <p class="font-extrabold text-text text-sm">Vaerbestandig</p>
          </div>
          <div class="bg-white rounded-2xl border border-border p-6 text-center">
            <div class="w-12 h-12 rounded-xl bg-primary-light flex items-center justify-center text-primary mx-auto mb-4">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg>
            </div>
            <p class="font-extrabold text-text text-sm">Holdbare materialer</p>
          </div>
          <div class="bg-white rounded-2xl border border-border p-6 text-center">
            <div class="w-12 h-12 rounded-xl bg-primary-light flex items-center justify-center text-primary mx-auto mb-4">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.098 19.902a3.75 3.75 0 0 0 5.304 0l6.401-6.402M6.75 21A3.75 3.75 0 0 1 3 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 0 0 3.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008Z"/></svg>
            </div>
            <p class="font-extrabold text-text text-sm">Presise farger</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-32 bg-accent">
    <div class="mx-auto max-w-4xl px-4 lg:px-6 text-center" data-reveal>
      <h2 class="text-3xl md:text-5xl font-extrabold text-white mb-6">Trenger du noe stort?</h2>
      <p class="text-lg md:text-xl text-white/90 mb-10 max-w-2xl mx-auto leading-relaxed">
        Fortell oss hva du ser for deg, sa finner vi den beste losningen for ditt prosjekt. Vi gir deg et uforpliktende tilbud innen kort tid.
      </p>
      <a href="/kontakt" class="inline-flex items-center gap-2 bg-white text-accent px-8 py-4 rounded-2xl font-semibold text-lg hover:bg-white/90 transition-colors">
        Ta kontakt
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
      </a>
    </div>
  </section>
</BaseLayout>
