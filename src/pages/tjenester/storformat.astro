---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';
import AnimatedCounter from '../../components/AnimatedCounter.astro';
---

<BaseLayout
  title="Storformat"
  description="Storformatprint fra Percor — bannere, rollups, plakater, fasadeskilt og messevegg. Fra idé til storslått synlighet."
>
  <Breadcrumbs items={[{ label: 'Tjenester', href: '/tjenester' }, { label: 'Storformat' }]} />

  <!-- 1. Hero — Set the scene -->
  <section class="relative bg-primary overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f1d2e] via-primary to-primary-light/40"></div>
      <div class="absolute top-1/4 right-1/4 w-[500px] h-[500px] bg-accent/8 rounded-full blur-[120px]"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 lg:px-6 py-24 md:py-36">
      <div data-reveal>
        <p class="text-accent-light font-semibold text-sm uppercase tracking-widest mb-6">Storformatprint</p>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold text-white max-w-4xl leading-[1.08]">
          Du har tre sekunder.
        </h1>
        <p class="mt-6 text-xl md:text-2xl text-white/70 max-w-2xl leading-relaxed font-light">
          Så lenge bruker et menneske på å bestemme om budskapet ditt er verdt oppmerksomheten. Storformat handler ikke om størrelse — det handler om å vinne de tre sekundene.
        </p>
      </div>
    </div>
  </section>

  <!-- 2. The Insight — Why size matters -->
  <section class="py-24 md:py-36 relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.02]" style="background-image: radial-gradient(circle at 1px 1px, var(--color-text) 1px, transparent 0); background-size: 24px 24px;"></div>

    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="max-w-4xl mx-auto text-center mb-20">
        <h2 data-reveal class="text-4xl md:text-5xl font-extrabold text-text leading-[1.1]">
          Tenk på siste gang du
        </h2>
        <h2 data-reveal class="text-4xl md:text-5xl font-extrabold text-text-light leading-[1.1] mt-2">
          stoppet opp og så opp.
        </h2>
        <p data-reveal class="mt-8 text-xl text-text-secondary leading-relaxed max-w-2xl mx-auto font-light">
          Et fasadeskilt som fanget lyset. Et banner som dekket hele veggen. En rollup som sto akkurat der blikket landet. <strong class="text-text font-semibold">Det var ikke tilfeldig.</strong>
        </p>
      </div>

      <!-- Three scenarios -->
      <div data-reveal-stagger class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        <!-- Scenario 1: Messen -->
        <div class="group relative">
          <div class="bg-white rounded-3xl border border-border p-8 h-full transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-12 h-12 rounded-2xl bg-violet-50 flex items-center justify-center">
                <svg class="w-6 h-6 text-violet-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18M7 16V9m4 7v-4m4 4V6m4 10V3"/></svg>
              </div>
              <span class="text-xs font-semibold text-violet-500 uppercase tracking-wider">Scenario</span>
            </div>
            <h3 class="text-xl font-bold text-text mb-3">Messen åpner om to timer.</h3>
            <p class="text-text-secondary text-sm leading-relaxed mb-6">
              120 utstillere. 3000 besøkende. Du har én stand og tre sekunder per forbipasserende. Rollup-en din må fortelle hele historien — hvem du er, hva du gjør, hvorfor de bør stoppe.
            </p>
            <div class="pt-5 border-t border-border">
              <div class="flex items-center gap-2 mb-2">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span class="text-sm font-semibold text-accent">Vår leveranse</span>
              </div>
              <p class="text-sm text-text-secondary">Rollups, bannere, veggdekor og stander som gjør at folk stopper.</p>
            </div>
          </div>
        </div>

        <!-- Scenario 2: Fasaden -->
        <div class="group relative">
          <div class="bg-white rounded-3xl border border-border p-8 h-full transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-12 h-12 rounded-2xl bg-blue-50 flex items-center justify-center">
                <svg class="w-6 h-6 text-blue-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 0 0 3.75-.615A2.993 2.993 0 0 0 9.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 0 0 2.25 1.016c.896 0 1.7-.393 2.25-1.015a3.001 3.001 0 0 0 3.75.614m-16.5 0a3.004 3.004 0 0 1-.621-4.72l1.189-1.19A1.5 1.5 0 0 1 5.378 3h13.243a1.5 1.5 0 0 1 1.06.44l1.19 1.189a3 3 0 0 1-.621 4.72M6.75 18h3.75a.75.75 0 0 0 .75-.75V13.5a.75.75 0 0 0-.75-.75H6.75a.75.75 0 0 0-.75.75v3.75c0 .414.336.75.75.75Z"/></svg>
              </div>
              <span class="text-xs font-semibold text-blue-500 uppercase tracking-wider">Scenario</span>
            </div>
            <h3 class="text-xl font-bold text-text mb-3">Butikken din trenger et ansikt.</h3>
            <p class="text-text-secondary text-sm leading-relaxed mb-6">
              Tusenvis passerer fasaden din hver dag. Uten skilting er du usynlig. Med riktig fasadeskilt og vindusdekor blir du et landemerke i nabolaget.
            </p>
            <div class="pt-5 border-t border-border">
              <div class="flex items-center gap-2 mb-2">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span class="text-sm font-semibold text-accent">Vår leveranse</span>
              </div>
              <p class="text-sm text-text-secondary">Fasadeskilt, vindusfolie, kampanjeplakater og lysskilt.</p>
            </div>
          </div>
        </div>

        <!-- Scenario 3: Kontoret -->
        <div class="group relative">
          <div class="bg-white rounded-3xl border border-border p-8 h-full transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-12 h-12 rounded-2xl bg-emerald-50 flex items-center justify-center">
                <svg class="w-6 h-6 text-emerald-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"/></svg>
              </div>
              <span class="text-xs font-semibold text-emerald-500 uppercase tracking-wider">Scenario</span>
            </div>
            <h3 class="text-xl font-bold text-text mb-3">Veggen er bare en vegg.</h3>
            <p class="text-text-secondary text-sm leading-relaxed mb-6">
              Med riktig grafikk forteller den bedriftens historie. Veggdekor, informasjonsskilt og sikkerhetsskilt — kontormiljøet blir en forlengelse av merkevaren.
            </p>
            <div class="pt-5 border-t border-border">
              <div class="flex items-center gap-2 mb-2">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span class="text-sm font-semibold text-accent">Vår leveranse</span>
              </div>
              <p class="text-sm text-text-secondary">Vegggrafikk, informasjonsskilt, frostet vindusfolie.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. The Arsenal — What we make -->
  <section class="py-24 md:py-36 bg-bg-alt">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="max-w-2xl mb-16" data-reveal>
        <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-4">Produkter</p>
        <h2 class="text-3xl md:text-5xl font-extrabold text-text leading-tight">Fra lommeformat til fasade.</h2>
        <p class="mt-4 text-lg text-text-secondary leading-relaxed">
          Alt vi produserer har én ting til felles: det er laget for å bli sett. Her er verktøyene vi bruker for å gjøre merkevaren din uunngåelig.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-reveal-stagger>
        <!-- Bannere -->
        <div class="group bg-white rounded-3xl border border-border p-8 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <div class="flex items-start gap-5">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-violet-100 to-violet-50 flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-7 h-7 text-violet-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3v1.5M3 21v-6m0 0 2.77-.693a9 9 0 0 1 6.208.682l.108.054a9 9 0 0 0 6.086.71l3.114-.732a48.524 48.524 0 0 1-.005-10.499l-3.11.732a9 9 0 0 1-6.085-.711l-.108-.054a9 9 0 0 0-6.208-.682L3 4.5M3 15V4.5"/></svg>
            </div>
            <div>
              <h3 class="text-xl font-bold text-text mb-2">Bannere</h3>
              <p class="text-text-secondary text-sm leading-relaxed mb-3">
                PVC, mesh eller stoff — i den størrelsen du trenger. Med øyer, lommer eller borrelås. Henges ute i all slags vær, eller inne for maksimal effekt.
              </p>
              <p class="text-xs text-text-light">Perfekt for: messer, byggeprosjekter, kampanjer</p>
            </div>
          </div>
        </div>

        <!-- Rollups -->
        <div class="group bg-white rounded-3xl border border-border p-8 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <div class="flex items-start gap-5">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-blue-100 to-blue-50 flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-7 h-7 text-blue-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 4.5v15m6-15v15m-10.875 0h15.75c.621 0 1.125-.504 1.125-1.125V5.625c0-.621-.504-1.125-1.125-1.125H4.125C3.504 4.5 3 5.004 3 5.625v12.75c0 .621.504 1.125 1.125 1.125Z"/></svg>
            </div>
            <div>
              <h3 class="text-xl font-bold text-text mb-2">Rollups</h3>
              <p class="text-text-secondary text-sm leading-relaxed mb-3">
                Fra budsjettmodeller til premiumkassetter. Bæresystem inkludert, klar på 30 sekunder. Den ultimate messe-følgesvennen — gjenbruk den hundrevis av ganger.
              </p>
              <p class="text-xs text-text-light">Perfekt for: messer, showroom, resepsjoner</p>
            </div>
          </div>
        </div>

        <!-- Fasadeskilt -->
        <div class="group bg-white rounded-3xl border border-border p-8 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <div class="flex items-start gap-5">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-amber-100 to-amber-50 flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-7 h-7 text-amber-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0 0 12 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75Z"/></svg>
            </div>
            <div>
              <h3 class="text-xl font-bold text-text mb-2">Fasadeskilt</h3>
              <p class="text-text-secondary text-sm leading-relaxed mb-3">
                Solide skilt i aluminium, akryl eller dibond. Med eller uten belysning. Designet for å tåle år med norsk vær — og for å gjøre butikken din til et landemerke.
              </p>
              <p class="text-xs text-text-light">Perfekt for: butikker, kontorer, restauranter</p>
            </div>
          </div>
        </div>

        <!-- Plakater & klistremerker -->
        <div class="group bg-white rounded-3xl border border-border p-8 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <div class="flex items-start gap-5">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-rose-100 to-rose-50 flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-7 h-7 text-rose-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6Z"/></svg>
            </div>
            <div>
              <h3 class="text-xl font-bold text-text mb-2">Plakater og klistremerker</h3>
              <p class="text-text-secondary text-sm leading-relaxed mb-3">
                Fra A3 til skreddersydde storformater. Innendørs på premiumpapir, utendørs på værbestandig syntetisk materiale. Klistremerker i enhver form — stanset, trykt og klart til bruk.
              </p>
              <p class="text-xs text-text-light">Perfekt for: kampanjer, produktmerking, gulvreklame</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. The Quality Story — Why it lasts -->
  <section class="relative py-24 md:py-36 bg-primary overflow-hidden section-slant-top section-slant-bottom">
    <div class="absolute inset-0">
      <div class="absolute top-0 left-1/3 w-[400px] h-[400px] bg-accent/10 rounded-full blur-[120px]"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 lg:px-6">
      <div class="max-w-3xl mx-auto text-center mb-16" data-reveal>
        <h2 class="text-3xl md:text-5xl font-extrabold text-white leading-tight">
          Hva skjer etter første regnskur?
        </h2>
        <p class="mt-6 text-lg text-white/60 leading-relaxed">
          Det er ingen vits i å gå stort hvis resultatet blekner i juni. Alt vi produserer er laget for å tåle det norske klimaet — og se like bra ut om tre år.
        </p>
      </div>

      <div data-reveal-stagger class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="bg-white/10 backdrop-blur-sm rounded-2xl border border-white/10 p-6 text-center">
          <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-accent-light" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
          </div>
          <p class="text-white font-bold text-sm">UV-bestandig blekk</p>
          <p class="text-white/50 text-xs mt-1">Holder fargene i årevis</p>
        </div>
        <div class="bg-white/10 backdrop-blur-sm rounded-2xl border border-white/10 p-6 text-center">
          <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-accent-light" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 0 0 4.5 4.5H18a3.75 3.75 0 0 0 1.332-7.257 3 3 0 0 0-3.758-3.848 5.25 5.25 0 0 0-10.233 2.33A4.502 4.502 0 0 0 2.25 15Z"/></svg>
          </div>
          <p class="text-white font-bold text-sm">Værbestandig</p>
          <p class="text-white/50 text-xs mt-1">Tåler norsk klima</p>
        </div>
        <div class="bg-white/10 backdrop-blur-sm rounded-2xl border border-white/10 p-6 text-center">
          <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-accent-light" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg>
          </div>
          <p class="text-white font-bold text-sm">Aluminium & akryl</p>
          <p class="text-white/50 text-xs mt-1">Solide materialer</p>
        </div>
        <div class="bg-white/10 backdrop-blur-sm rounded-2xl border border-white/10 p-6 text-center">
          <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-accent-light" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.098 19.902a3.75 3.75 0 0 0 5.304 0l6.401-6.402M6.75 21A3.75 3.75 0 0 1 3 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 0 0 3.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008Z"/></svg>
          </div>
          <p class="text-white font-bold text-sm">Presise farger</p>
          <p class="text-white/50 text-xs mt-1">PMS og CMYK</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. The Numbers — Impact stats -->
  <section class="py-24 md:py-32">
    <div class="mx-auto max-w-5xl px-4 lg:px-6">
      <div class="text-center mb-16" data-reveal>
        <h2 class="text-3xl md:text-4xl font-extrabold text-text">Synlighet i tall</h2>
      </div>
      <div data-reveal-stagger class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div class="text-center">
          <p class="text-4xl md:text-5xl font-extrabold text-primary">
            <AnimatedCounter value="5" suffix=" m²+" />
          </p>
          <p class="text-sm text-text-secondary mt-2">Maks bredde per bane</p>
        </div>
        <div class="text-center">
          <p class="text-4xl md:text-5xl font-extrabold text-primary">
            <AnimatedCounter value="1440" suffix=" dpi" />
          </p>
          <p class="text-sm text-text-secondary mt-2">Oppløsning</p>
        </div>
        <div class="text-center">
          <p class="text-4xl md:text-5xl font-extrabold text-primary">
            <AnimatedCounter value="5" suffix="+" />
          </p>
          <p class="text-sm text-text-secondary mt-2">År holdbarhet utendørs</p>
        </div>
        <div class="text-center">
          <p class="text-4xl md:text-5xl font-extrabold text-primary">
            <AnimatedCounter value="3" />
          </p>
          <p class="text-sm text-text-secondary mt-2">Dagers leveringstid</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. CTA -->
  <section class="relative py-24 md:py-32 bg-accent overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-white/10 rounded-full blur-[100px]"></div>
    </div>
    <div class="relative mx-auto max-w-4xl px-4 lg:px-6 text-center" data-reveal>
      <h2 class="text-3xl md:text-5xl font-extrabold text-white mb-6">
        Klar for å bli lagt merke til?
      </h2>
      <p class="text-lg md:text-xl text-white/90 mb-10 max-w-2xl mx-auto leading-relaxed">
        Fortell oss hva du trenger — messestand, fasadeskilt, eller noe helt annet. Vi gir deg et uforpliktende tilbud innen én arbeidsdag.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/kontakt" class="inline-flex items-center gap-2 bg-white text-accent px-8 py-4 rounded-2xl font-semibold text-lg hover:bg-white/90 transition-colors shadow-lg">
          Ta kontakt
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
