---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';

const techniques = [
  {
    title: 'Broderi',
    subtitle: 'Den klassiske',
    desc: 'Noen ting blir bare bedre med tid. Broderi gir logoen din et eksklusivt, taktilt uttrykk som taler kvalitet. Tralene sitter fast gjennom hundrevis av vask uten a miste farge eller form.',
    bestFor: 'Poloer, caps og arbeidstoy',
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/></svg>`,
  },
  {
    title: 'Screentrykk',
    subtitle: 'Arbeidshesten',
    desc: 'Nar du trenger 200 t-skjorter til sommerfesten eller 500 arbeidsjakker til hele organisasjonen, er screentrykk det selvfolgelige valget. Jo storre opplag, jo lavere pris per enhet — med farger som virkelig popper.',
    bestFor: 'Store opplag og sterke farger',
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0l.229 2.523a1.125 1.125 0 01-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0021 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 00-1.913-.247M6.34 18H5.25A2.25 2.25 0 013 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 011.913-.247m10.5 0a48.536 48.536 0 00-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18.75 12h.008v.008h-.008V12zm-2.25 0h.008v.008H16.5V12z"/></svg>`,
  },
  {
    title: 'DTF-trykk',
    subtitle: 'Fremtidens teknikk',
    desc: 'Direct-to-Film er den nyeste revolusjonen innen tekstiltrykk. Full fargefrihet, ingen minstekrav til antall, og resultatet ser fantastisk ut pa bade lyse og morke tekstiler. Perfekt nar du vil ha fotorealistiske detaljer.',
    bestFor: 'Sma opplag og fullfarge',
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>`,
  },
  {
    title: 'Transfer',
    subtitle: 'Den fleksible',
    desc: 'Har du et fotografi, en kompleks illustrasjon eller et design med mange fargenyanser? Varmoverforingstrykk handterer det elegant. Rask produksjon og god holdbarhet gjor dette til et trygt valg for mellomstore bestillinger.',
    bestFor: 'Foto og komplekse motiver',
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21zM8.25 8.625a1.125 1.125 0 100-2.25 1.125 1.125 0 000 2.25z"/></svg>`,
  },
  {
    title: 'Sublimering',
    subtitle: 'Den grensellose',
    desc: 'Tenk deg at fargene smelter inn i selve stoffet — det er sublimering. Resultatet er et trykk du ikke kan kjenne med fingrene, som aldri flasser eller falmer. Ideelt for heldekkende design pa polyester.',
    bestFor: 'Heldekkende trykk pa polyester',
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/></svg>`,
  },
];

const steps = [
  {
    num: '01',
    title: 'Send oss logoen din',
    desc: 'Last opp logoen din eller send den pa e-post. Vi godtar de fleste filformater — AI, EPS, PDF, PNG eller til og med et bilde fra telefonen.',
  },
  {
    num: '02',
    title: 'Vi foreslar teknikk og plassering',
    desc: 'Basert pa materiale, antall og design anbefaler vi den teknikken som gir best resultat. Du far et komplett tilbud uten forpliktelser.',
  },
  {
    num: '03',
    title: 'Du godkjenner provetrykk',
    desc: 'For vi setter i gang produksjonen, lager vi et provetrykk slik at du kan se og kjenne pa resultatet. Ingenting gar i trykken for du sier ja.',
  },
  {
    num: '04',
    title: 'Ferdig levert pa 2–3 uker',
    desc: 'Vi trykker, kvalitetskontrollerer og leverer rett til doren din. Hastelevering er ogsa mulig — bare si ifra.',
  },
];

const faqs = [
  {
    q: 'Hvilken teknikk er best for sma opplag?',
    a: 'DTF-trykk og transfer er ideelle for sma opplag, da de ikke krever kostbare oppsett som screentrykk. Du kan fa like lavt som 1 enhet uten at prisen blir urimelig.',
  },
  {
    q: 'Kan dere trykke pa arbeidstoy vi allerede har?',
    a: 'Ja, absolutt. Send oss gjerne plaggene, sa trykker vi direkte pa dem. Vi trykker pa alt fra t-skjorter og hettegensere til arbeidsjakker og forklær.',
  },
  {
    q: 'Hva er leveringstiden?',
    a: 'Normal leveringstid er 2–3 uker fra godkjent provetrykk. Ved hasteordre kan vi ofte levere innen 5–7 virkedager — ta kontakt sa finner vi en losning.',
  },
  {
    q: 'Hvor mye koster tekstiltrykk?',
    a: 'Prisen avhenger av teknikk, antall farger, plassering og opplag. Send oss en henvendelse med detaljer, sa far du et uforpliktende tilbud innen 24 timer.',
  },
];
---

<BaseLayout
  title="Tekstiltrykk"
  description="Tekstiltrykk fra Percor — broderi, screentrykk, DTF-trykk, transfer og sublimering. Fra logo til ferdig produkt pa 2–3 uker."
  schemaType="faqPage"
>
  <Breadcrumbs items={[{ label: 'Tjenester', href: '/tjenester' }, { label: 'Tekstiltrykk' }]} />

  <!-- Hero -->
  <section class="relative bg-primary overflow-hidden">
    <div class="absolute inset-0 opacity-[0.07]">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,var(--color-primary-light)_0%,transparent_60%)]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_80%_20%,var(--color-accent)_0%,transparent_40%)]"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 lg:px-6 py-20 md:py-32">
      <div class="max-w-3xl">
        <p data-reveal class="text-accent-light font-semibold text-sm uppercase tracking-wider mb-4">Tekstiltrykk</p>
        <h1 data-reveal class="text-4xl md:text-6xl font-extrabold text-white leading-tight">
          Din logo.<br />Pa hva som helst.
        </h1>
        <p data-reveal class="mt-6 text-lg md:text-xl text-dark-text-secondary max-w-2xl leading-relaxed">
          Fem teknikker. En leverandor. Vi mestrer broderi, screentrykk, DTF, transfer og sublimering — slik at logoen din alltid far den behandlingen den fortjener.
        </p>
      </div>
    </div>
  </section>

  <!-- The Story Hook -->
  <section class="py-20 md:py-32">
    <div class="mx-auto max-w-4xl px-4 lg:px-6">
      <div data-reveal class="relative bg-bg-alt rounded-2xl p-8 md:p-12 border border-border">
        <div class="absolute -top-4 left-8">
          <span class="bg-accent text-white text-sm font-bold px-4 py-1.5 rounded-full">Tenk deg dette</span>
        </div>
        <p class="text-lg md:text-xl text-text leading-relaxed mt-4">
          Det er mandag morgen. Du har nettopp landet en stor kontrakt, og teamet pa 30 skal representere bedriften pa en messe om tre uker. Alle trenger profilerte jakker, poloer og caps — med logoen pa rett plass, i riktig farge, pa riktig materiale.
        </p>
        <p class="text-lg md:text-xl text-text leading-relaxed mt-4">
          Du sender oss en e-post med logoen. Vi tar det derfra.
        </p>
        <p class="text-text-secondary mt-6 flex items-center gap-2">
          <svg class="w-5 h-5 text-accent shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2m6-2a10 10 0 11-20 0 10 10 0 0120 0z"/></svg>
          Neste steg? Vi finner ut hvilken teknikk som passer best til hvert plagg.
        </p>
      </div>
    </div>
  </section>

  <!-- Techniques Section -->
  <section class="py-20 md:py-32 bg-bg-alt">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="text-center mb-16" data-reveal>
        <h2 class="text-3xl md:text-4xl font-extrabold text-text">Fem teknikker. Ett mal.</h2>
        <p class="mt-4 text-lg text-text-secondary max-w-2xl mx-auto">
          Hver teknikk har sin styrke. Vi velger den rette basert pa ditt design, ditt materiale og ditt budsjett.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" data-reveal-stagger>
        {techniques.map((t) => (
          <div class="card-3d">
            <div class="card-3d-inner bg-white rounded-2xl border border-border p-8 h-full flex flex-col">
              <div class="text-accent mb-4" set:html={t.icon} />
              <p class="text-xs font-semibold uppercase tracking-wider text-text-secondary mb-1">{t.subtitle}</p>
              <h3 class="text-xl font-extrabold text-text mb-3">{t.title}</h3>
              <p class="text-text-secondary text-sm leading-relaxed flex-grow">{t.desc}</p>
              <div class="mt-6 pt-4 border-t border-border">
                <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-accent">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  Best for: {t.bestFor}
                </span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process Timeline -->
  <section class="py-20 md:py-32">
    <div class="mx-auto max-w-4xl px-4 lg:px-6">
      <div class="text-center mb-16" data-reveal>
        <h2 class="text-3xl md:text-4xl font-extrabold text-text">Fra logo til ferdig produkt</h2>
        <p class="mt-4 text-lg text-text-secondary max-w-2xl mx-auto">
          Fire enkle steg er alt som star mellom deg og profilerte tekstiler.
        </p>
      </div>

      <div class="timeline-line space-y-12 md:space-y-16">
        {steps.map((step, i) => (
          <div
            class={`relative flex flex-col md:flex-row items-start gap-6 ${i % 2 === 0 ? '' : 'md:flex-row-reverse'}`}
            data-reveal={i % 2 === 0 ? 'left' : 'right'}
          >
            <div class="flex items-center gap-4 md:w-1/2 md:justify-end">
              <div class={`${i % 2 === 0 ? 'md:text-right' : 'md:text-left'} ${i % 2 !== 0 ? 'md:order-1' : ''}`}>
                <span class="text-5xl font-extrabold text-accent/20">{step.num}</span>
              </div>
            </div>
            <div class="hidden md:flex items-center justify-center shrink-0">
              <div class="w-4 h-4 rounded-full bg-accent border-4 border-accent-light z-10"></div>
            </div>
            <div class="md:w-1/2">
              <div class="bg-white rounded-2xl border border-border p-6 shadow-sm">
                <h3 class="text-lg font-extrabold text-text mb-2">{step.title}</h3>
                <p class="text-text-secondary text-sm leading-relaxed">{step.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 md:py-32 bg-bg-alt">
    <div class="mx-auto max-w-3xl px-4 lg:px-6">
      <div class="text-center mb-12" data-reveal>
        <h2 class="text-3xl md:text-4xl font-extrabold text-text">Vanlige sporsmal</h2>
        <p class="mt-4 text-text-secondary">Alt du lurer pa om tekstiltrykk — samlet pa ett sted.</p>
      </div>
      <div class="space-y-4" data-reveal-stagger>
        {faqs.map((faq) => (
          <details class="group bg-white rounded-2xl border border-border">
            <summary class="flex items-center justify-between cursor-pointer p-6 font-semibold text-text">
              {faq.q}
              <svg class="w-5 h-5 text-text-secondary shrink-0 ml-4 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-6 text-text-secondary leading-relaxed">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-32 bg-accent relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_30%,white_0%,transparent_50%)]"></div>
    </div>
    <div class="relative mx-auto max-w-4xl px-4 lg:px-6 text-center" data-reveal>
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4">Klar for a sette logoen din pa klærne?</h2>
      <p class="text-lg text-white/90 mb-10 max-w-2xl mx-auto leading-relaxed">
        Send oss logoen din og fortell hva du trenger. Vi kommer tilbake med forslag til teknikk, plassering og pris — innen 24 timer.
      </p>
      <a
        href="/kontakt"
        class="inline-flex items-center gap-2 bg-white text-accent px-8 py-4 rounded-2xl font-bold text-lg hover:bg-white/90 transition-colors shadow-lg hover:shadow-xl"
      >
        Start prosjektet ditt
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
      </a>
    </div>
  </section>
</BaseLayout>
