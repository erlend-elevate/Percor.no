---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';
---

<BaseLayout
  title="Foliering"
  description="Profesjonell foliering av bil, lastebil, butikkvindu og kontor. Gjør hver kilometer til en reklame med Percor."
>
  <Breadcrumbs items={[{ label: 'Tjenester', href: '/tjenester' }, { label: 'Foliering' }]} />

  <!-- 1. Hero — The Opening -->
  <section class="relative bg-primary overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-gradient-to-br from-accent/20 to-transparent"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 lg:px-6 py-20 md:py-32">
      <div data-reveal>
        <p class="text-accent-light font-semibold text-sm uppercase tracking-wider mb-4">Foliering</p>
        <h1 class="text-4xl md:text-6xl font-extrabold text-white max-w-3xl leading-tight">
          Gjør hver kilometer til en reklame.
        </h1>
        <p class="mt-6 text-lg md:text-xl text-dark-text-secondary max-w-2xl leading-relaxed">
          Kjøretøyet ditt er allerede på veien. Vinduene dine vender allerede mot fortauet. Kontorveggene er allerede der.
          Spørsmålet er: jobber de for merkevaren din?
        </p>
        <p class="mt-4 text-base text-dark-text-secondary/70 max-w-xl">
          Med profesjonell foliering blir hver overflate en 24/7-reklamekanal — uten løpende kostnader.
        </p>
      </div>
    </div>
  </section>

  <!-- 2. The Transformation — Før og etter -->
  <section class="py-20 md:py-32 bg-bg-alt">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="text-center mb-16" data-reveal>
        <h2 class="text-3xl md:text-4xl font-extrabold text-text">Før og etter</h2>
        <p class="mt-4 text-lg text-text-secondary max-w-2xl mx-auto">
          Se forskjellen foliering gjør. Fra usynlig til uforglemmelig — på en dag.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <!-- For -->
        <div class="rounded-2xl border-2 border-border bg-white p-8 relative" data-reveal="left">
          <div class="absolute top-4 right-4 bg-gray-200 text-gray-500 text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full">Før</div>
          <div class="flex items-center justify-center w-16 h-16 rounded-xl bg-gray-100 mb-6">
            <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <rect x="3" y="8" width="18" height="10" rx="2" />
              <circle cx="7.5" cy="18" r="2" />
              <circle cx="16.5" cy="18" r="2" />
              <path d="M3 12h18" />
            </svg>
          </div>
          <h3 class="text-xl font-extrabold text-gray-400 mb-3">En hvit varebil</h3>
          <p class="text-gray-400 leading-relaxed">
            Et anonymt kjøretøy i trafikken. Ingen vet hvem du er, hva du gjør, eller hvordan de kan nå deg.
            Tusenvis av visninger — bortkastet, hver eneste dag.
          </p>
          <div class="mt-6 pt-6 border-t border-border">
            <div class="flex items-center gap-3 text-gray-400">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18.364 5.636a9 9 0 11-12.728 0" /><path d="M12 9v4l3 3" /></svg>
              <span class="text-sm">0 visninger per dag</span>
            </div>
          </div>
        </div>

        <!-- Etter -->
        <div class="rounded-2xl border-2 border-accent bg-white p-8 relative shadow-lg" data-reveal="right">
          <div class="absolute top-4 right-4 bg-accent text-white text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full">Etter</div>
          <div class="flex items-center justify-center w-16 h-16 rounded-xl bg-accent-subtle mb-6">
            <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <rect x="3" y="8" width="18" height="10" rx="2" />
              <circle cx="7.5" cy="18" r="2" />
              <circle cx="16.5" cy="18" r="2" />
              <path d="M3 12h18" />
              <path d="M8 10l2 2 4-4" stroke-width="2" />
            </svg>
          </div>
          <h3 class="text-xl font-extrabold text-text mb-3">En mobil reklameplakat</h3>
          <p class="text-text-secondary leading-relaxed">
            Profesjonell foliering med logo, farger og kontaktinfo. Hver tur til jobb, hvert oppdrag, hver parkering
            — alt blir en markedsføringsmulighet.
          </p>
          <div class="mt-6 pt-6 border-t border-accent/20">
            <div class="flex items-center gap-3 text-accent">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
              <span class="text-sm font-semibold">Opptil 70 000 visninger per dag</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Services Grid — Tjenestene våre -->
  <section class="py-20 md:py-32">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="text-center mb-16" data-reveal>
        <h2 class="text-3xl md:text-4xl font-extrabold text-text">Foliering for enhver overflate</h2>
        <p class="mt-4 text-lg text-text-secondary max-w-2xl mx-auto">
          Uansett om det er en varebil, en trailer, et butikkvindu eller et kontorlokale — vi gjør det til noe folk legger merke til.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8" data-reveal-stagger>
        <!-- Bilfoliering -->
        <div class="card-3d">
          <div class="card-3d-inner rounded-2xl border border-border bg-white p-8 h-full">
            <div class="flex items-center justify-center w-14 h-14 rounded-xl bg-accent-subtle mb-6">
              <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M5 17h14M5 17a2 2 0 01-2-2v-3a1 1 0 011-1h1l2-4h10l2 4h1a1 1 0 011 1v3a2 2 0 01-2 2M5 17a2 2 0 002 2h1a2 2 0 002-2M14 17a2 2 0 002 2h1a2 2 0 002-2" />
                <circle cx="7.5" cy="17" r="0.5" fill="currentColor" />
                <circle cx="16.5" cy="17" r="0.5" fill="currentColor" />
              </svg>
            </div>
            <h3 class="text-xl font-extrabold text-text mb-3">Bilfoliering</h3>
            <p class="text-text-secondary leading-relaxed mb-4">
              Flåten din kjører allerede hundrevis av kilometer i uken. Med bilfoliering blir hver tur en investering i synlighet.
              Full foliering, delvis dekor eller fargebytte — vi tilpasser etter dine behov.
            </p>
            <p class="text-sm text-accent font-semibold">Gjør flåten til en rullende reklameplakat</p>
          </div>
        </div>

        <!-- Lastebildekor -->
        <div class="card-3d">
          <div class="card-3d-inner rounded-2xl border border-border bg-white p-8 h-full">
            <div class="flex items-center justify-center w-14 h-14 rounded-xl bg-accent-subtle mb-6">
              <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M1 13h15V5H1v8zm0 0l-0 3a1 1 0 001 1h1m13-4h3l3 4v3h-1" />
                <circle cx="5" cy="17" r="2" />
                <circle cx="19" cy="17" r="2" />
                <path d="M9 17h6" />
              </svg>
            </div>
            <h3 class="text-xl font-extrabold text-text mb-3">Lastebildekor</h3>
            <p class="text-text-secondary leading-relaxed mb-4">
              En lastebil på motorveien er umulig å overse. Med heldekkende dekor går budskapet ditt gjennom byer, tettsteder og
              regioner — dag etter dag, uke etter uke.
            </p>
            <p class="text-sm text-accent font-semibold">Umulig å ignorere på veien</p>
          </div>
        </div>

        <!-- Vindusfolie -->
        <div class="card-3d">
          <div class="card-3d-inner rounded-2xl border border-border bg-white p-8 h-full">
            <div class="flex items-center justify-center w-14 h-14 rounded-xl bg-accent-subtle mb-6">
              <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <rect x="3" y="3" width="18" height="18" rx="2" />
                <path d="M3 12h18M12 3v18" />
                <path d="M7 7h2v2H7zM15 15h2v2h-2z" fill="currentColor" opacity="0.3" />
              </svg>
            </div>
            <h3 class="text-xl font-extrabold text-text mb-3">Vindusfolie</h3>
            <p class="text-text-secondary leading-relaxed mb-4">
              Butikkvinduene dine er den første kontakten med kundene. Vindusfolie gir deg personvern, solbeskyttelse
              og merkevarebygging — alt i ett.
            </p>
            <p class="text-sm text-accent font-semibold">Personvern og branding i ett</p>
          </div>
        </div>

        <!-- Kontordekor -->
        <div class="card-3d">
          <div class="card-3d-inner rounded-2xl border border-border bg-white p-8 h-full">
            <div class="flex items-center justify-center w-14 h-14 rounded-xl bg-accent-subtle mb-6">
              <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M3 21V7l9-4 9 4v14" />
                <path d="M9 21V11h6v10" />
                <path d="M3 7l9 4 9-4" />
              </svg>
            </div>
            <h3 class="text-xl font-extrabold text-text mb-3">Kontordekor</h3>
            <p class="text-text-secondary leading-relaxed mb-4">
              Førsteinntrykket starter i resepsjonen. Med foliering av glassvegger, møterom og fellesarealer
              skaper du et helhetlig visuelt uttrykk som styrker merkevaren innenfra.
            </p>
            <p class="text-sm text-accent font-semibold">Få rommet til å matche merkevaren</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Why Foliering — Fordelene -->
  <section class="py-20 md:py-32 bg-bg-alt">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="text-center mb-16" data-reveal>
        <h2 class="text-3xl md:text-4xl font-extrabold text-text">Hvorfor foliering?</h2>
        <p class="mt-4 text-lg text-text-secondary max-w-2xl mx-auto">
          Foliering er en av de smarteste investeringene du kan gjøre for merkevaren din. Her er grunnene.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8" data-reveal-stagger>
        <!-- 5+ år holdbarhet -->
        <div class="rounded-2xl bg-white border border-border p-8 text-center">
          <div class="flex items-center justify-center w-16 h-16 rounded-full bg-accent-subtle mx-auto mb-5">
            <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="9" />
              <path d="M12 7v5l3.5 3.5" />
            </svg>
          </div>
          <p class="text-3xl font-extrabold text-text mb-2">5+ år</p>
          <p class="text-sm text-text-secondary font-medium">holdbarhet med folie av høy kvalitet</p>
        </div>

        <!-- Beskytter originallakk -->
        <div class="rounded-2xl bg-white border border-border p-8 text-center">
          <div class="flex items-center justify-center w-16 h-16 rounded-full bg-accent-subtle mx-auto mb-5">
            <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M12 2l7 4v6c0 5-3.5 9.74-7 11-3.5-1.26-7-6-7-11V6l7-4z" />
              <path d="M9 12l2 2 4-4" stroke-width="2" />
            </svg>
          </div>
          <p class="text-3xl font-extrabold text-text mb-2">Beskytter</p>
          <p class="text-sm text-text-secondary font-medium">originallakken mot riper og vær</p>
        </div>

        <!-- Fjernes uten skade -->
        <div class="rounded-2xl bg-white border border-border p-8 text-center">
          <div class="flex items-center justify-center w-16 h-16 rounded-full bg-accent-subtle mx-auto mb-5">
            <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M4 12h16" />
              <path d="M12 4l-4 8h8l-4 8" />
              <path d="M19 6l-14 14" stroke-width="0.5" stroke-dasharray="2 2" />
            </svg>
          </div>
          <p class="text-3xl font-extrabold text-text mb-2">Skadefritt</p>
          <p class="text-sm text-text-secondary font-medium">fjernes uten å skade overflaten</p>
        </div>

        <!-- Billigere enn lakkering -->
        <div class="rounded-2xl bg-white border border-border p-8 text-center">
          <div class="flex items-center justify-center w-16 h-16 rounded-full bg-accent-subtle mx-auto mb-5">
            <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" />
            </svg>
          </div>
          <p class="text-3xl font-extrabold text-text mb-2">Billigere</p>
          <p class="text-sm text-text-secondary font-medium">enn lakkering — med større fleksibilitet</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Process — Slik jobber vi -->
  <section class="py-20 md:py-32">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="text-center mb-16" data-reveal>
        <h2 class="text-3xl md:text-4xl font-extrabold text-text">Fra idé til ferdig resultat</h2>
        <p class="mt-4 text-lg text-text-secondary max-w-2xl mx-auto">
          Tre enkle steg er alt som står mellom deg og en profesjonelt foliert overflate.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto" data-reveal-stagger>
        <!-- Steg 1 -->
        <div class="rounded-2xl border border-border bg-white p-8 relative">
          <div class="flex items-center justify-center w-12 h-12 rounded-full bg-accent text-white font-extrabold text-lg mb-6">
            1
          </div>
          <h3 class="text-xl font-extrabold text-text mb-3">Befaring og design</h3>
          <p class="text-text-secondary leading-relaxed">
            Vi kommer til deg, tar mål og diskuterer dine ønsker. Så lager vi en digital visning
            slik at du ser resultatet før vi starter.
          </p>
        </div>

        <!-- Steg 2 -->
        <div class="rounded-2xl border border-border bg-white p-8 relative">
          <div class="flex items-center justify-center w-12 h-12 rounded-full bg-accent text-white font-extrabold text-lg mb-6">
            2
          </div>
          <h3 class="text-xl font-extrabold text-text mb-3">Produksjon</h3>
          <p class="text-text-secondary leading-relaxed">
            Folien produseres med høyoppløselig trykk på værbestandig kvalitetsfolie. Alt tilpasses
            ned til millimeteren.
          </p>
        </div>

        <!-- Steg 3 -->
        <div class="rounded-2xl border border-border bg-white p-8 relative">
          <div class="flex items-center justify-center w-12 h-12 rounded-full bg-accent text-white font-extrabold text-lg mb-6">
            3
          </div>
          <h3 class="text-xl font-extrabold text-text mb-3">Montering</h3>
          <p class="text-text-secondary leading-relaxed">
            Våre erfarne montører legger folien presisjonsfullt — uten bobler, uten rynker.
            Resultatet? En finish som ser ut som den alltid har vært der.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. CTA — Avslutningen -->
  <section class="py-20 md:py-32 bg-primary">
    <div class="mx-auto max-w-4xl px-4 lg:px-6 text-center" data-reveal>
      <h2 class="text-3xl md:text-5xl font-extrabold text-white mb-6">
        La bilene dine jobbe for deg
      </h2>
      <p class="text-lg md:text-xl text-dark-text-secondary max-w-2xl mx-auto mb-10 leading-relaxed">
        Hver dag kjøretøyet ditt er uten foliering, er en dag med tapte visninger. Ta det første steget — vi tar oss av resten.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/kontakt"
          class="inline-flex items-center gap-2 bg-accent hover:bg-accent/90 text-white px-8 py-4 rounded-xl font-semibold text-lg transition-colors"
        >
          Få et uforpliktende tilbud
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
        </a>
        <a
          href="/kontakt"
          class="inline-flex items-center gap-2 border-2 border-white/30 hover:border-white/60 text-white px-8 py-4 rounded-xl font-semibold text-lg transition-colors"
        >
          Bestill befaring
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
