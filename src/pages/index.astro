---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import StoryIntro from '../components/sections/StoryIntro.astro';
import CategoryGrid from '../components/sections/CategoryGrid.astro';
import TechniqueShowcase from '../components/sections/TechniqueShowcase.astro';
import ProcessSteps from '../components/sections/ProcessSteps.astro';
import PayperHighlight from '../components/sections/PayperHighlight.astro';
import BrandShowcase from '../components/sections/BrandShowcase.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import QuoteFlow from '../components/sections/QuoteFlow.astro';
import BlogTeaser from '../components/sections/BlogTeaser.astro';
import NewsletterSignup from '../components/sections/NewsletterSignup.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';
---

<BaseLayout
  title="Hjem"
  description="Percor er din totalleverandør av arbeidstøy, profilklær, tekstiltrykk, foliering og grafisk design. Eksklusiv norsk importør av Payper."
  schemaType="localBusiness"
>
  <!-- Act 1: Hook — who we are, why you should care -->
  <Hero />

  <!-- Act 2: The problem — why this matters -->
  <StoryIntro />

  <!-- Act 3: How we solve it — four service areas -->
  <CategoryGrid />

  <!-- Act 4: What we master — horizontal technique scroll -->
  <TechniqueShowcase />

  <!-- Act 5: The process — from idea to delivery -->
  <ProcessSteps />

  <!-- Act 6: Our edge — Payper exclusive -->
  <PayperHighlight />

  <!-- Act 7: All the brands -->
  <BrandShowcase />

  <!-- Act 8: Proof — customer stories -->
  <Testimonials />

  <!-- Act 9: Start your project — interactive quote form -->
  <QuoteFlow />

  <!-- Act 10: Blog + newsletter -->
  <BlogTeaser />
  <NewsletterSignup />

  <!-- Finale: CTA -->
  <CtaBanner />
</BaseLayout>
