---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';
import Accordion from '../components/ui/Accordion.astro';
import faqData from '../data/faq.json';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqData.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer.replace(/<[^>]*>/g, ''),
    },
  })),
};
---

<BaseLayout
  title="FAQ"
  description="Ofte stilte spørsmål om Percors tjenester, produkter, leveringstid og bestilling. Finn svar på det du lurer på."
  schemaType="faqPage"
  schemaData={faqSchema}
>
  <div class="mx-auto max-w-7xl px-4 lg:px-6">
    <Breadcrumbs items={[{ label: 'FAQ' }]} />
  </div>

  <!-- Hero -->
  <section class="relative bg-primary overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f1d2e] via-primary to-primary-light/40"></div>
      <div class="absolute bottom-0 left-1/3 w-[400px] h-[400px] bg-accent/8 rounded-full blur-[120px]"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 lg:px-6 py-20 md:py-28 text-center">
      <p data-reveal class="text-accent-light font-semibold text-sm uppercase tracking-widest mb-6">Vanlige spørsmål</p>
      <h1 data-reveal class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white">Spør oss om hva som helst.</h1>
      <p data-reveal class="mt-6 text-lg md:text-xl text-white/60 max-w-2xl mx-auto leading-relaxed">
        Her er svarene på det kundene våre oftest lurer på. Finner du ikke svaret? Ring oss — vi biter ikke.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 md:py-28">
    <div class="mx-auto max-w-3xl px-4 lg:px-6" data-reveal>
      <Accordion items={faqData} />
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-28 bg-bg-alt">
    <div class="mx-auto max-w-4xl px-4 lg:px-6 text-center" data-reveal>
      <h2 class="text-3xl md:text-4xl font-extrabold text-text mb-4">Fant du ikke svar?</h2>
      <p class="text-lg text-text-secondary mb-10 max-w-xl mx-auto">
        Ingen spørsmål er for dumme. Ta kontakt, så hjelper vi deg videre.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/kontakt" class="inline-flex items-center gap-2 bg-primary text-white px-8 py-4 rounded-2xl font-semibold text-lg hover:bg-primary-light transition-colors shadow-lg">
          Send oss en melding
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="tel:+4790772409" class="inline-flex items-center gap-2 bg-white text-text border border-border px-8 py-4 rounded-2xl font-semibold text-lg hover:bg-bg-alt transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
          Ring 907 72 409
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
