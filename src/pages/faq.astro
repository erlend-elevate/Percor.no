---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';
import Accordion from '../components/ui/Accordion.astro';
import faqData from '../data/faq.json';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqData.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer.replace(/<[^>]*>/g, ''),
    },
  })),
};
---

<BaseLayout
  title="FAQ"
  description="Ofte stilte sporsmal om Percors tjenester, produkter, leveringstid og bestilling. Finn svar pa det du lurer pa."
  schemaType="faqPage"
  schemaData={faqSchema}
>
  <Breadcrumbs items={[{ label: 'FAQ' }]} />

  <!-- Hero -->
  <section class="relative bg-primary overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-gradient-to-br from-primary-lighter/20 to-transparent"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 lg:px-6 py-16 md:py-24 text-center">
      <p class="text-accent-light font-semibold text-sm uppercase tracking-wider mb-4">Hjelp</p>
      <h1 class="text-4xl md:text-5xl font-bold text-white">Ofte stilte sporsmal</h1>
      <p class="mt-4 text-lg md:text-xl text-dark-text-secondary max-w-2xl mx-auto">
        Her finner du svar pa de vanligste sporsmålene om vare produkter og tjenester.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-3xl px-4 lg:px-6">
      <Accordion items={faqData} />
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-bg-alt">
    <div class="mx-auto max-w-4xl px-4 lg:px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-text mb-4">Fant du ikke svar?</h2>
      <p class="text-lg text-text-secondary mb-8 max-w-2xl mx-auto">
        Ta kontakt med oss direkte, sa hjelper vi deg gjerne.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/kontakt" class="inline-flex items-center gap-2 bg-primary text-white px-7 py-3.5 rounded-lg font-semibold hover:bg-primary-light transition-colors">
          Kontakt oss
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="tel:+4790772409" class="inline-flex items-center gap-2 bg-white text-text border border-border px-7 py-3.5 rounded-lg font-semibold hover:bg-bg-alt transition-colors">
          Ring 907 72 409
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
