---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';

const shopUrl = 'https://butikk.percor.no';

const categories = [
  {
    name: 'Drakter',
    desc: 'Komplette draktsett for fotball, handball, basketball og volleyball. Tilgjengelig i utallige fargekombinasjoner med mulighet for full tilpasning.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>`,
  },
  {
    name: 'Treningsklær',
    desc: 'Funksjonelle treningsklær for oppvarming, trening og reise. Designet for bevegelsesfrihet og komfort i alle faser av treningen.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.546 5.974 5.974 0 01-2.133-1A3.75 3.75 0 0012 18z"/></svg>`,
  },
  {
    name: 'Sportsutstyr',
    desc: 'Bagger, ryggsekker, drikkeflasker og annet tilbehør som fullfører lagets utrustning. Alt med mulighet for trykk av lagets logo.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>`,
  },
];

const timeline = [
  { year: 'Opprinnelse', text: 'Grunnlagt i Italia med en visjon om å gjøre kvalitetssportsklær tilgjengelig for alle lag.' },
  { year: 'Vekst', text: 'Ekspansjon til over 40 land — fra lokale klubber i Sør-Italia til profesjonelle lag i hele Europa.' },
  { year: 'I dag', text: 'Et foretrukket valg for norske idrettslag som ønsker italiensk kvalitet til fornuftige priser.' },
];
---

<BaseLayout
  title="Zeus Sport — Italienske drakter og sportsutstyr | Percor"
  description="Zeus Sport leverer italienske sportsdrakter, treningsklær og utstyr for lag og foreninger. Komplett lagpakker tilgjengelig hos Percor med trykk og profilering."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-[#0f1d2e] via-primary to-primary-light/40 py-20 md:py-32">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 right-1/4 w-72 h-72 bg-violet-500 rounded-full blur-3xl"></div>
      <div class="absolute bottom-20 left-10 w-96 h-96 bg-violet-300 rounded-full blur-3xl"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 lg:px-6">
      <Breadcrumbs items={[{ label: 'Merkevarer', href: '/merkevarer' }, { label: 'Zeus Sport' }]} />

      <div class="mt-8 grid md:grid-cols-2 gap-12 items-center">
        <div data-reveal>
          <div class="inline-flex items-center gap-2 mb-6">
            <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-violet-600 text-white text-xs font-bold">IT</span>
            <span class="text-violet-300 font-semibold text-sm uppercase tracking-wider">Italienske drakter og sportsutstyr</span>
          </div>
          <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight">
            Italiensk <span class="text-violet-400">sportsarv</span> for norske lag
          </h1>
          <p class="text-lg md:text-xl text-white/70 leading-relaxed mb-8 max-w-xl">
            Fra lokale fotballklubber i Sør-Italia til garderobene til norske idrettslag. Zeus Sport bringer italiensk design, kvalitet og lidenskap til enhver idrettsarena.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href={shopUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-violet-600 text-white px-7 py-3.5 rounded-xl font-semibold hover:bg-violet-500 transition-all duration-300 hover:-translate-y-0.5 shadow-lg shadow-violet-600/25">
              Handle Zeus Sport
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
            </a>
            <a href="/kontakt" class="inline-flex items-center gap-2 bg-white/10 text-white px-7 py-3.5 rounded-xl font-semibold hover:bg-white/20 transition-all duration-300 backdrop-blur-sm border border-white/10">
              Få tilbud for laget
            </a>
          </div>
        </div>

        <div data-reveal="right" class="hidden md:flex justify-center">
          <div class="relative">
            <div class="w-72 h-72 rounded-full bg-gradient-to-br from-violet-600/30 to-violet-400/10 flex items-center justify-center border border-violet-500/20">
              <div class="w-48 h-48 rounded-full bg-gradient-to-br from-violet-600/40 to-transparent flex items-center justify-center">
                <svg class="w-24 h-24 text-white/80" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
              </div>
            </div>
            <div class="absolute -bottom-4 -left-4 bg-violet-600/20 backdrop-blur-sm border border-violet-500/30 rounded-2xl px-4 py-2">
              <span class="text-violet-300 text-sm font-semibold">40+ land</span>
            </div>
            <div class="absolute -top-2 -right-6 bg-violet-600/20 backdrop-blur-sm border border-violet-500/30 rounded-2xl px-4 py-2">
              <span class="text-violet-300 text-sm font-semibold">Made in Italy</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Brand Story / Timeline -->
  <section class="py-20 md:py-28">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div data-reveal="left">
          <span class="text-violet-600 font-semibold text-sm uppercase tracking-wider">Historien bak merket</span>
          <h2 class="text-3xl md:text-4xl font-bold text-text mt-3 mb-6">Fra italienske baner til norske haller</h2>
          <div class="space-y-4 text-text-secondary text-lg leading-relaxed">
            <p>
              Italia er synonymt med sport — og Zeus Sport bærer den arven videre. Merket ble grunnlagt med en enkel idé: at hvert lag, uansett størrelse eller budsjett, fortjener klær som får dem til å føle seg som profesjonelle.
            </p>
            <p>
              Det som startet som en lokal leverandør i Italia, har vokst til et internasjonalt merke som kler lag i over 40 land. I Norge har Zeus Sport blitt et populært valg for fotballklubber, håndballag og andre idrettsforeninger som ønsker kvalitet uten å betale toppris.
            </p>
          </div>
        </div>

        <div data-reveal="right">
          <div class="space-y-6">
            {timeline.map((item, i) => (
              <div class="flex gap-5">
                <div class="flex flex-col items-center">
                  <div class="w-12 h-12 rounded-2xl bg-violet-100 text-violet-700 flex items-center justify-center font-bold text-xs shrink-0">
                    {item.year.slice(0, 3).toUpperCase()}
                  </div>
                  {i < timeline.length - 1 && <div class="w-0.5 flex-1 bg-violet-200 mt-2"></div>}
                </div>
                <div class="pb-8">
                  <h3 class="font-bold text-text mb-1">{item.year}</h3>
                  <p class="text-text-secondary leading-relaxed">{item.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Product Categories -->
  <section class="py-20 md:py-28 bg-bg-alt">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="text-center max-w-2xl mx-auto mb-16" data-reveal>
        <span class="text-violet-600 font-semibold text-sm uppercase tracking-wider">Sortiment</span>
        <h2 class="text-3xl md:text-4xl font-bold text-text mt-3 mb-4">Komplett utrustning for laget</h2>
        <p class="text-text-secondary text-lg leading-relaxed">
          Zeus Sport dekker alt fra kampdrakter til treningsklær og tilbehør — slik at hele laget er samkjort.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-reveal-stagger>
        {categories.map(cat => (
          <div class="group bg-white rounded-3xl border border-border p-8 hover:-translate-y-1 hover:shadow-xl transition-all duration-300">
            <div class="w-14 h-14 rounded-2xl bg-violet-50 text-violet-600 flex items-center justify-center mb-6 group-hover:bg-violet-600 group-hover:text-white transition-all duration-300" set:html={cat.icon}></div>
            <h3 class="text-xl font-bold text-text mb-3">{cat.name}</h3>
            <p class="text-text-secondary leading-relaxed">{cat.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Zeus through Percor -->
  <section class="py-20 md:py-28">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="max-w-3xl mx-auto" data-reveal>
        <div class="text-center mb-12">
          <span class="text-violet-600 font-semibold text-sm uppercase tracking-wider">Fordeler</span>
          <h2 class="text-3xl md:text-4xl font-bold text-text mt-3 mb-4">Hvorfor Zeus Sport gjennom Percor?</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6" data-reveal-stagger>
          <div class="bg-white rounded-3xl border border-border p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
            <div class="w-12 h-12 rounded-2xl bg-violet-50 text-violet-600 flex items-center justify-center mb-4 font-bold">01</div>
            <h3 class="font-bold text-text mb-2">Komplette lagpakker</h3>
            <p class="text-text-secondary text-sm leading-relaxed">Vi setter sammen komplette pakker med drakter, treningsklær, bagger og tilbehør tilpasset lagets behov og budsjett.</p>
          </div>
          <div class="bg-white rounded-3xl border border-border p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
            <div class="w-12 h-12 rounded-2xl bg-violet-50 text-violet-600 flex items-center justify-center mb-4 font-bold">02</div>
            <h3 class="font-bold text-text mb-2">Full tilpasning</h3>
            <p class="text-text-secondary text-sm leading-relaxed">Trykk av lagets logo, sponsorer, spillernavn og nummer på alle plagg — alt håndtert av Percor.</p>
          </div>
          <div class="bg-white rounded-3xl border border-border p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
            <div class="w-12 h-12 rounded-2xl bg-violet-50 text-violet-600 flex items-center justify-center mb-4 font-bold">03</div>
            <h3 class="font-bold text-text mb-2">Design-hjelp</h3>
            <p class="text-text-secondary text-sm leading-relaxed">Trenger laget nytt design? Vi hjelper med å sette sammen farger, layout og profil som gir laget en unik identitet.</p>
          </div>
          <div class="bg-white rounded-3xl border border-border p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
            <div class="w-12 h-12 rounded-2xl bg-violet-50 text-violet-600 flex items-center justify-center mb-4 font-bold">04</div>
            <h3 class="font-bold text-text mb-2">Konkurransedyktige priser</h3>
            <p class="text-text-secondary text-sm leading-relaxed">Italiensk kvalitet til priser som passer for foreninger og klubber. Gode rabatter ved større bestillinger.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative overflow-hidden py-20 md:py-28 bg-gradient-to-br from-violet-700 via-violet-600 to-violet-500">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 left-1/3 w-96 h-96 bg-white rounded-full blur-3xl"></div>
    </div>
    <div class="relative mx-auto max-w-4xl px-4 lg:px-6 text-center" data-reveal>
      <h2 class="text-3xl md:text-5xl font-bold text-white mb-6">
        Trenger laget ditt nye drakter?
      </h2>
      <p class="text-lg md:text-xl text-white/80 mb-10 max-w-2xl mx-auto leading-relaxed">
        Kontakt oss for et komplett tilbud med drakter, treningsklær og tilbehør. Vi hjelper laget fra idé til ferdig levert pakke.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/kontakt" class="inline-flex items-center gap-2 bg-white text-violet-700 px-8 py-4 rounded-xl font-semibold hover:bg-white/90 transition-all duration-300 hover:-translate-y-0.5 shadow-lg">
          Kontakt oss
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href={shopUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-white/15 text-white px-8 py-4 rounded-xl font-semibold hover:bg-white/25 transition-all duration-300 backdrop-blur-sm border border-white/20">
          Besøk nettbutikken
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
