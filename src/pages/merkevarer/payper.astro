---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';

const shopUrl = 'https://butikk.percor.no';

const categories = [
  { name: 'Arbeidstøy', desc: 'Slitesterkt arbeidstøy for alle bransjer og arbeidsforhold.' },
  { name: 'Profilklær', desc: 'Profilering med stil — poloskjorter, gensere og mer.' },
  { name: 'T-skjorter', desc: 'Stort utvalg t-skjorter i alle farger og størrelser.' },
  { name: 'Jakker', desc: 'Fra softshell til vinterjakker — for alle sesonger.' },
  { name: 'Bukser', desc: 'Arbeidsbukser, shorts og fritidsbukser.' },
  { name: 'High-Vis', desc: 'Synlighetsklær som oppfyller norske HMS-krav.' },
];
---

<BaseLayout
  title="Payper"
  description="Percor er eksklusiv norsk importør og distributør av Payper — italiensk arbeidstøy og profilklær av høyeste kvalitet siden 1977."
>
  <section class="bg-primary py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <Breadcrumbs items={[{ label: 'Merkevarer', href: '/merkevarer' }, { label: 'Payper' }]} />
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="inline-flex items-center gap-2 bg-accent text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider mb-4">
            Eksklusiv norsk forhandler
          </span>
          <h1 class="text-3xl md:text-5xl font-bold text-white mb-4">
            Payper <span class="text-4xl md:text-5xl">🇮🇹</span>
          </h1>
          <p class="text-accent-light font-semibold text-sm uppercase tracking-wider mb-4">Italiensk kvalitet siden 1977</p>
          <p class="text-lg text-dark-text-secondary leading-relaxed mb-6">
            Percor er stolt eksklusiv importør og distributør av Payper i Norge. Med over 500 produkter i sortimentet leverer Payper arbeidstøy og profilklær som kombinerer italiensk design med funksjonalitet og holdbarhet.
          </p>
          <ul class="space-y-2 text-dark-text-secondary mb-8">
            <li class="flex items-center gap-2">
              <svg class="w-5 h-5 text-accent-light flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
              Eksklusiv importør i Norge — direkte fra produsent
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-5 h-5 text-accent-light flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
              Italiensk kvalitet og design siden 1977
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-5 h-5 text-accent-light flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
              Over 500 produkter — fra t-skjorter til high-vis
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-5 h-5 text-accent-light flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
              Raske leveranser fra norsk lager
            </li>
          </ul>
          <div class="flex flex-wrap gap-4">
            <a href={shopUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-accent text-white px-6 py-3 rounded-lg font-semibold hover:bg-accent-light transition-colors">
              Handle Payper i nettbutikken
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
            </a>
            <a href="/kontakt" class="inline-flex items-center gap-2 bg-white/10 text-white px-6 py-3 rounded-lg font-semibold hover:bg-white/20 transition-colors backdrop-blur-sm">
              Be om tilbud
            </a>
          </div>
        </div>
        <div class="bg-white/5 rounded-2xl p-8 lg:p-12 backdrop-blur-sm border border-white/10">
          <div class="text-center">
            <span class="text-6xl mb-4 block">🇮🇹</span>
            <h2 class="text-2xl font-bold text-white mb-2">Payper</h2>
            <p class="text-dark-text-secondary text-sm mb-6">Made in Italy — Since 1977</p>
            <div class="grid grid-cols-2 gap-4 text-center">
              <div class="bg-white/5 rounded-lg p-4">
                <p class="text-2xl font-bold text-accent-light">500+</p>
                <p class="text-xs text-dark-text-secondary mt-1">Produkter</p>
              </div>
              <div class="bg-white/5 rounded-lg p-4">
                <p class="text-2xl font-bold text-accent-light">40+</p>
                <p class="text-xs text-dark-text-secondary mt-1">År erfaring</p>
              </div>
              <div class="bg-white/5 rounded-lg p-4">
                <p class="text-2xl font-bold text-accent-light">1</p>
                <p class="text-xs text-dark-text-secondary mt-1">Norsk distributør</p>
              </div>
              <div class="bg-white/5 rounded-lg p-4">
                <p class="text-2xl font-bold text-accent-light">100%</p>
                <p class="text-xs text-dark-text-secondary mt-1">Italiensk</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="max-w-3xl mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">Produktkategorier</h2>
        <p class="text-text-secondary leading-relaxed">
          Payper tilbyr et komplett sortiment for bedrifter som trenger arbeidstøy og profilklær av høy kvalitet. Alt kan tilpasses med trykk og broderi gjennom Percor.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {categories.map(cat => (
          <div class="bg-white rounded-xl border border-border p-6 hover:shadow-md transition-shadow">
            <h3 class="text-lg font-bold text-text mb-2">{cat.name}</h3>
            <p class="text-sm text-text-secondary leading-relaxed">{cat.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-bg-alt">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold text-text mb-6">Hvorfor velge Payper gjennom Percor?</h2>
        <div class="prose prose-lg text-text-secondary">
          <p>
            Som eksklusiv norsk importør av Payper kan Percor tilby konkurransedyktige priser direkte fra den italienske produsenten. Vi holder et bredt utvalg på norsk lager, noe som sikrer raske leveranser til kunder over hele landet.
          </p>
          <p>
            Payper har siden 1977 produsert arbeidstøy og profilklær med fokus på kvalitet, komfort og design. Den italienske produksjonen sikrer at hvert plagg holder en standard som tåler daglig bruk i krevende arbeidsmiljøer.
          </p>
          <p>
            I tillegg til standardsortimentet tilbyr vi trykk, broderi og fullstendig profilering av alle Payper-produkter. Enten du trenger en liten ordre eller store volumer, hjelper vi deg hele veien.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-accent">
    <div class="mx-auto max-w-4xl px-4 lg:px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Klar for å bestille Payper?
      </h2>
      <p class="text-lg text-white/90 mb-8 max-w-2xl mx-auto">
        Besøk nettbutikken vår eller ta kontakt for et skreddersydd tilbud med trykk og profilering.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/kontakt" class="inline-flex items-center gap-2 bg-white text-accent px-7 py-3.5 rounded-lg font-semibold hover:bg-white/90 transition-colors">
          Be om tilbud
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href={shopUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-white/20 text-white px-7 py-3.5 rounded-lg font-semibold hover:bg-white/30 transition-colors backdrop-blur-sm">
          Besøk nettbutikken
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
