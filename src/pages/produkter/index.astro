---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';

const shopUrl = 'https://butikk.percor.no';

const categories = [
  {
    title: 'Arbeidstøy',
    description: 'Klær som tåler jobben. Bukser med forsterket kneledd, jakker som holder deg varm på stillas, kjeledresser som overlever skiftene. Skandinavisk kvalitet for skandinavisk arbeidshverdag.',
    brands: [
      { name: 'Payper', href: '/merkevarer/payper' },
      { name: 'L.Brador', href: '/merkevarer/l-brador' },
    ],
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085"/>',
    color: 'blue',
  },
  {
    title: 'Profilklær',
    description: 'T-skjorter, pikéer, hettegensere og softshell — lerretet for merkevaren din. Hundrevis av farger, alle størrelser, klar for trykk eller broderi.',
    brands: [
      { name: 'Payper', href: '/merkevarer/payper' },
      { name: 'Roly', href: '/merkevarer/roly' },
      { name: 'Stamina', href: '/merkevarer/stamina' },
    ],
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/>',
    color: 'emerald',
  },
  {
    title: 'Verneutstyr',
    description: 'Når sikkerhet ikke er valgfritt. Vernesko, hjelmer, hansker og HMS-utstyr fra Nordens ledende leverandør — alt sertifisert og klart for bruk.',
    brands: [
      { name: 'Skydda', href: '/merkevarer/skydda' },
    ],
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/>',
    color: 'amber',
  },
  {
    title: 'Sportsutstyr',
    description: 'Drakter, treningsklær og utstyr for lag og foreninger. Italiensk sport-DNA med fokus på passform, holdbarhet og pris — fra breddefotball til seriespill.',
    brands: [
      { name: 'Zeus Sport', href: '/merkevarer/zeus-sport' },
    ],
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 0 1 3 3h-15a3 3 0 0 1 3-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 0 1-.982-3.172M9.497 14.25a7.454 7.454 0 0 0 .982-3.172M8.25 8.25a6 6 0 1 1 7.5 0"/>',
    color: 'violet',
  },
];

const colorMap: Record<string, { bg: string; icon: string; badge: string }> = {
  blue: { bg: 'bg-blue-50', icon: 'text-blue-600', badge: 'bg-blue-100 text-blue-700' },
  emerald: { bg: 'bg-emerald-50', icon: 'text-emerald-600', badge: 'bg-emerald-100 text-emerald-700' },
  amber: { bg: 'bg-amber-50', icon: 'text-amber-600', badge: 'bg-amber-100 text-amber-700' },
  violet: { bg: 'bg-violet-50', icon: 'text-violet-600', badge: 'bg-violet-100 text-violet-700' },
};
---

<BaseLayout
  title="Produkter"
  description="Utforsk Percors produktutvalg: arbeidstøy, profilklær, verneutstyr og sportsutstyr fra Payper, L.Brador, Roly og flere."
>
  <div class="mx-auto max-w-7xl px-4 lg:px-6">
    <Breadcrumbs items={[{ label: 'Produkter' }]} />
  </div>

  <!-- Hero -->
  <section class="relative bg-primary overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f1d2e] via-primary to-primary-light/40"></div>
      <div class="absolute top-1/4 right-1/4 w-[400px] h-[400px] bg-accent/8 rounded-full blur-[120px]"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 lg:px-6 py-20 md:py-28">
      <div class="max-w-3xl">
        <p data-reveal class="text-accent-light font-semibold text-sm uppercase tracking-widest mb-6">Produkter</p>
        <h1 data-reveal class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-[1.08]">
          Riktig utstyr gjør<br/>
          <span class="text-white/50">hele forskjellen.</span>
        </h1>
        <p data-reveal class="mt-6 text-lg md:text-xl text-white/60 max-w-xl leading-relaxed">
          Fra arbeidsplagg som tåler alt til profilklær som representerer deg. Seks merkevarer, tusenvis av produkter — alle tilgjengelige med trykk og profilering.
        </p>
        <div data-reveal class="mt-10">
          <a href={shopUrl} target="_blank" rel="noopener" class="group inline-flex items-center gap-2 bg-accent text-white px-8 py-4 rounded-xl font-semibold hover:bg-accent-light transition-all shadow-lg shadow-accent/25">
            Gå til nettbutikken
            <svg class="w-4 h-4 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="py-20 md:py-32">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="max-w-2xl mb-16" data-reveal>
        <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-4">Kategorier</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-text">Hva trenger du?</h2>
      </div>

      <div class="space-y-6" data-reveal-stagger>
        {categories.map((cat) => {
          const colors = colorMap[cat.color];
          return (
            <div class="bg-white rounded-3xl border border-border p-8 md:p-10 hover:shadow-xl transition-all duration-300">
              <div class="flex flex-col md:flex-row md:items-start gap-6">
                <div class={`w-16 h-16 rounded-2xl ${colors.bg} flex items-center justify-center flex-shrink-0`}>
                  <svg class={`w-8 h-8 ${colors.icon}`} fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><Fragment set:html={cat.icon} /></svg>
                </div>
                <div class="flex-1">
                  <h3 class="text-2xl font-extrabold text-text mb-3">{cat.title}</h3>
                  <p class="text-text-secondary leading-relaxed mb-5">{cat.description}</p>
                  <div class="flex flex-wrap items-center gap-3">
                    {cat.brands.map((brand) => (
                      <a href={brand.href} class={`text-xs font-semibold px-3 py-1.5 rounded-full ${colors.badge} hover:opacity-80 transition-opacity`}>
                        {brand.name}
                      </a>
                    ))}
                    <a href={shopUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary hover:text-primary-light transition-colors ml-auto">
                      Handle
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-24 md:py-32 bg-accent overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-white/10 rounded-full blur-[100px]"></div>
    </div>
    <div class="relative mx-auto max-w-4xl px-4 lg:px-6 text-center" data-reveal>
      <h2 class="text-3xl md:text-5xl font-extrabold text-white mb-6">Trenger du større volum?</h2>
      <p class="text-lg md:text-xl text-white/90 mb-10 max-w-2xl mx-auto leading-relaxed">
        Vi tilbyr bedriftspriser, dedikert oppfølging og skreddersydd profilering. Én kontaktperson som kjenner deg og dine behov.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/bedrift" class="inline-flex items-center gap-2 bg-white text-accent px-8 py-4 rounded-2xl font-semibold text-lg hover:bg-white/90 transition-colors shadow-lg">
          For bedrifter
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/kontakt" class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm text-white px-8 py-4 rounded-2xl font-semibold text-lg hover:bg-white/30 transition-colors">
          Be om tilbud
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
