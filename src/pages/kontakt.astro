---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';
import ContactForm from '../components/ui/ContactForm.astro';
---

<BaseLayout
  title="Kontakt"
  description="Ta kontakt med Percor AS. Ring 907 72 409, send e-post til stein@percor.no, eller besøk oss på Åsveien 5, 3475 Sætre."
>
  <Breadcrumbs items={[{ label: 'Kontakt' }]} />

  <!-- Hero -->
  <section class="relative bg-primary overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-gradient-to-br from-primary-lighter/20 to-transparent"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 lg:px-6 py-16 md:py-24 text-center">
      <p class="text-accent-light font-semibold text-sm uppercase tracking-wider mb-4">Kontakt oss</p>
      <h1 class="text-4xl md:text-5xl font-bold text-white">Vi hører gjerne fra deg</h1>
      <p class="mt-4 text-lg md:text-xl text-dark-text-secondary max-w-2xl mx-auto">
        Send oss en melding, ring eller kom innom. Vi er alltid klare for en prat.
      </p>
    </div>
  </section>

  <!-- Kontaktinfo + skjema -->
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Kontaktinfo -->
        <div class="lg:col-span-1 space-y-8">
          <div>
            <h2 class="text-2xl font-bold text-text mb-6">Kontaktinformasjon</h2>
            <ul class="space-y-5">
              <li class="flex items-start gap-3">
                <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z"/><circle cx="12" cy="11" r="3"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-text">Adresse</p>
                  <p class="text-text-secondary">Åsveien 5</p>
                  <p class="text-text-secondary">3475 Sætre</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-text">Telefon</p>
                  <a href="tel:+4790772409" class="text-primary hover:underline">907 72 409</a>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-text">E-post</p>
                  <a href="mailto:stein@percor.no" class="text-primary hover:underline">stein@percor.no</a>
                </div>
              </li>
            </ul>
          </div>

          <div>
            <h3 class="text-lg font-bold text-text mb-3">Åpningstider</h3>
            <div class="space-y-1.5 text-text-secondary text-sm">
              <div class="flex justify-between"><span>Mandag - Fredag</span><span class="font-medium text-text">08:00 - 16:00</span></div>
              <div class="flex justify-between"><span>Lørdag - Søndag</span><span class="font-medium text-text">Stengt</span></div>
            </div>
          </div>
        </div>

        <!-- Kontaktskjema -->
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold text-text mb-6">Send oss en melding</h2>
          <ContactForm showCompany={true} />
        </div>
      </div>
    </div>
  </section>

  <!-- Kart -->
  <section class="py-16 md:py-20 bg-bg-alt">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="text-center max-w-2xl mx-auto mb-8">
        <h2 class="text-3xl md:text-4xl font-bold text-text">Finn oss</h2>
        <p class="mt-3 text-text-secondary">Åsveien 5, 3475 Sætre</p>
      </div>
      <div class="bg-bg-alt border border-border rounded-xl flex items-center justify-center h-80">
        <div class="text-center text-text-light">
          <svg class="w-12 h-12 mx-auto mb-3 opacity-40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z"/><circle cx="12" cy="11" r="3"/></svg>
          <p class="text-lg font-medium">Kart</p>
          <p class="text-sm mt-1">Google Maps-integrering kommer her</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
