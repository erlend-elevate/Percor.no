---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';
import ContactForm from '../components/ui/ContactForm.astro';
---

<BaseLayout
  title="Kontakt"
  description="Ta kontakt med Percor AS. Ring 907 72 409, send e-post til stein@percor.no, eller besøk oss på Åsveien 5, 3475 Sætre."
>
  <div class="mx-auto max-w-7xl px-4 lg:px-6">
    <Breadcrumbs items={[{ label: 'Kontakt' }]} />
  </div>

  <!-- Hero -->
  <section class="relative bg-primary overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f1d2e] via-primary to-primary-light/60"></div>
      <div class="absolute bottom-0 right-1/4 w-[400px] h-[400px] bg-accent/8 rounded-full blur-[100px]"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 lg:px-6 py-20 md:py-28">
      <div class="max-w-2xl">
        <p data-reveal class="text-accent-light font-semibold text-sm uppercase tracking-widest mb-6">La oss snakke</p>
        <h1 data-reveal class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-[1.1]">
          Fortell oss hva<br />du trenger.
        </h1>
        <p data-reveal class="mt-6 text-lg text-white/60 leading-relaxed max-w-lg">
          Vi svarer innen én arbeidsdag med et forslag skreddersydd for deg. Ingen forpliktelser.
        </p>
      </div>
    </div>
  </section>

  <!-- Quick contact options -->
  <section class="relative -mt-8 z-10 mb-8">
    <div class="mx-auto max-w-5xl px-4 lg:px-6">
      <div data-reveal-stagger class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="tel:+4790772409" class="group bg-white rounded-2xl border border-border p-6 flex items-center gap-4 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200">
          <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center flex-shrink-0 group-hover:bg-accent/20 transition-colors">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
          </div>
          <div>
            <p class="font-semibold text-text">Ring oss</p>
            <p class="text-sm text-primary font-medium">907 72 409</p>
          </div>
        </a>

        <a href="mailto:stein@percor.no" class="group bg-white rounded-2xl border border-border p-6 flex items-center gap-4 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200">
          <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0 group-hover:bg-primary/15 transition-colors">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
          </div>
          <div>
            <p class="font-semibold text-text">E-post</p>
            <p class="text-sm text-primary font-medium">stein@percor.no</p>
          </div>
        </a>

        <div class="bg-white rounded-2xl border border-border p-6 flex items-center gap-4">
          <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
          </div>
          <div>
            <p class="font-semibold text-text">Besøk oss</p>
            <p class="text-sm text-text-secondary">Åsveien 5, 3475 Sætre</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Form + info grid -->
  <section class="py-12 md:py-20">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
        <!-- Form (3/5) -->
        <div class="lg:col-span-3" data-reveal>
          <h2 class="text-2xl font-extrabold text-text mb-2">Send oss en melding</h2>
          <p class="text-text-secondary mb-8">Fyll ut skjemaet, så tar vi kontakt.</p>
          <ContactForm showCompany={true} />
        </div>

        <!-- Info sidebar (2/5) -->
        <div class="lg:col-span-2" data-reveal="right">
          <div class="bg-bg-alt rounded-3xl p-8 space-y-8">
            <div>
              <h3 class="text-lg font-bold text-text mb-4">Åpningstider</h3>
              <div class="space-y-2.5 text-sm">
                <div class="flex justify-between">
                  <span class="text-text-secondary">Mandag – Fredag</span>
                  <span class="font-semibold text-text">08:00 – 16:00</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-text-secondary">Lørdag – Søndag</span>
                  <span class="font-semibold text-text-light">Stengt</span>
                </div>
              </div>
            </div>

            <div class="border-t border-border pt-8">
              <h3 class="text-lg font-bold text-text mb-4">Hva kan vi hjelpe med?</h3>
              <ul class="space-y-3">
                <li class="flex items-start gap-3 text-sm text-text-secondary">
                  <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4"/></svg>
                  Tilbud på arbeidstøy og profilklær
                </li>
                <li class="flex items-start gap-3 text-sm text-text-secondary">
                  <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4"/></svg>
                  Tekstiltrykk og broderi
                </li>
                <li class="flex items-start gap-3 text-sm text-text-secondary">
                  <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4"/></svg>
                  Foliering av kjøretøy og lokaler
                </li>
                <li class="flex items-start gap-3 text-sm text-text-secondary">
                  <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4"/></svg>
                  Storformat og skilt
                </li>
                <li class="flex items-start gap-3 text-sm text-text-secondary">
                  <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4"/></svg>
                  Logo og grafisk design
                </li>
              </ul>
            </div>

            <div class="border-t border-border pt-8">
              <h3 class="text-lg font-bold text-text mb-3">Rask respons</h3>
              <p class="text-sm text-text-secondary leading-relaxed">
                Vi svarer på alle henvendelser innen én arbeidsdag. For hasteoppdrag — ring oss direkte.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map placeholder -->
  <section class="py-12 md:py-16 bg-bg-alt">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div data-reveal class="bg-white border border-border rounded-3xl flex items-center justify-center h-80 overflow-hidden">
        <div class="text-center text-text-light">
          <svg class="w-10 h-10 mx-auto mb-3 opacity-30" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24"><path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
          <p class="font-medium">Åsveien 5, 3475 Sætre</p>
          <p class="text-sm mt-1 text-text-light">Kart kommer snart</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
