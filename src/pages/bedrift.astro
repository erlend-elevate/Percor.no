---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';
import AnimatedCounter from '../components/AnimatedCounter.astro';
import ContactForm from '../components/ui/ContactForm.astro';

const shopUrl = 'https://butikk.percor.no';
---

<BaseLayout
  title="For bedrifter"
  description="Percor leverer arbeidstøy, profilklær, trykk, foliering og design til bedrifter. Én kontaktperson, én faktura, null koordinering."
>
  <div class="mx-auto max-w-7xl px-4 lg:px-6">
    <Breadcrumbs items={[{ label: 'For bedrifter' }]} />
  </div>

  <!-- 1. Hero — The Promise -->
  <section class="relative bg-primary overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f1d2e] via-primary to-primary-light/40"></div>
      <div class="absolute bottom-0 left-1/4 w-[500px] h-[500px] bg-accent/8 rounded-full blur-[120px]"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 lg:px-6 py-24 md:py-36">
      <div class="max-w-3xl">
        <p data-reveal class="text-accent-light font-semibold text-sm uppercase tracking-widest mb-6">For bedrifter</p>
        <h1 data-reveal class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-[1.08]">
          Du fortjener én partner.<br/>
          <span class="text-white/50">Ikke fire leverandører.</span>
        </h1>
        <p data-reveal class="mt-6 text-lg md:text-xl text-white/60 max-w-xl leading-relaxed">
          Arbeidstøy fra én. Trykk fra en annen. Design fra en tredje. Foliering fra en fjerde. Vi erstatter alle fire med én dedikert kontaktperson som kjenner bedriften din.
        </p>
        <div data-reveal class="mt-10 flex flex-wrap gap-4">
          <a href="#kontakt-bedrift" class="inline-flex items-center gap-2 bg-accent text-white px-7 py-3.5 rounded-xl font-semibold hover:bg-accent/90 transition-colors shadow-lg shadow-accent/25">
            Be om tilbud
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href={shopUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm text-white px-7 py-3.5 rounded-xl font-semibold hover:bg-white/20 transition-colors">
            Se nettbutikken
            <svg class="w-3.5 h-3.5 opacity-70" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. The Story — What a partnership looks like -->
  <section class="py-24 md:py-36 relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.02]" style="background-image: radial-gradient(circle at 1px 1px, var(--color-text) 1px, transparent 0); background-size: 24px 24px;"></div>

    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="max-w-4xl mx-auto text-center mb-20">
        <h2 data-reveal class="text-4xl md:text-5xl font-extrabold text-text leading-[1.1]">
          Slik ser et partnerskap ut.
        </h2>
        <p data-reveal class="mt-8 text-xl text-text-secondary leading-relaxed max-w-2xl mx-auto font-light">
          Se for deg dette: Du sender én e-post. Én person tar seg av resten. Klærne matcher trykket. Bilene matcher fasaden. Alt henger sammen — fordi én person har oversikten.
        </p>
      </div>

      <!-- Timeline narrative -->
      <div class="max-w-3xl mx-auto space-y-0">
        <!-- Step 1 -->
        <div class="relative pl-12 pb-12 border-l-2 border-border" data-reveal="left">
          <div class="absolute left-0 top-0 -translate-x-1/2 w-10 h-10 rounded-full bg-accent text-white flex items-center justify-center font-bold text-sm">1</div>
          <div class="bg-white rounded-2xl border border-border p-6">
            <h3 class="text-lg font-bold text-text mb-2">Du tar kontakt</h3>
            <p class="text-text-secondary text-sm leading-relaxed">
              «Vi trenger 40 jakker med logo, broderi på brystet, og kanskje foliering av to varebiler.» Det er alt vi trenger. Vi tar det derfra.
            </p>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="relative pl-12 pb-12 border-l-2 border-border" data-reveal="left">
          <div class="absolute left-0 top-0 -translate-x-1/2 w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-bold text-sm">2</div>
          <div class="bg-white rounded-2xl border border-border p-6">
            <h3 class="text-lg font-bold text-text mb-2">Vi setter sammen et forslag</h3>
            <p class="text-text-secondary text-sm leading-relaxed">
              Din kontaktperson finner riktig jakke, velger trykkmetode, tilpasser designet for broderi og foliering, og sender deg ett samlet tilbud. Ingen overraskelser.
            </p>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="relative pl-12 pb-12 border-l-2 border-border" data-reveal="left">
          <div class="absolute left-0 top-0 -translate-x-1/2 w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-bold text-sm">3</div>
          <div class="bg-white rounded-2xl border border-border p-6">
            <h3 class="text-lg font-bold text-text mb-2">Vi produserer alt under ett tak</h3>
            <p class="text-text-secondary text-sm leading-relaxed">
              Broderi, trykk og foliering skjer i vårt eget verksted i Sætre. Fordi alt gjøres på samme sted, matcher fargene og kvaliteten — hver gang.
            </p>
          </div>
        </div>

        <!-- Step 4 -->
        <div class="relative pl-12" data-reveal="left">
          <div class="absolute left-0 top-0 -translate-x-1/2 w-10 h-10 rounded-full bg-accent text-white flex items-center justify-center font-bold text-sm">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M4.5 12.75l6 6 9-13.5"/></svg>
          </div>
          <div class="bg-accent/5 rounded-2xl border border-accent/20 p-6">
            <h3 class="text-lg font-bold text-text mb-2">Du mottar alt samlet</h3>
            <p class="text-text-secondary text-sm leading-relaxed">
              40 jakker med broderi. To ferdig folierte varebiler. Én faktura. Og en kontaktperson du kan ringe neste gang du trenger noe.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. What you get — The advantages -->
  <section class="py-24 md:py-32 bg-bg-alt">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="text-center mb-16" data-reveal>
        <h2 class="text-3xl md:text-5xl font-extrabold text-text">Hva betyr det for deg?</h2>
      </div>

      <div data-reveal-stagger class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white rounded-3xl border border-border p-8 text-center hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <div class="w-14 h-14 rounded-2xl bg-accent/10 flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-text mb-2">Bedre priser</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Ingen mellomledd. Volumrabatter. Jo mer du samler hos oss, desto bedre blir prisen per enhet.
          </p>
        </div>

        <div class="bg-white rounded-3xl border border-border p-8 text-center hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-text mb-2">Én kontaktperson</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Samme person hver gang. Kjenner bedriften din, historikken, og hva som fungerer.
          </p>
        </div>

        <div class="bg-white rounded-3xl border border-border p-8 text-center hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <div class="w-14 h-14 rounded-2xl bg-violet-100 flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-violet-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>
          </div>
          <h3 class="text-lg font-bold text-text mb-2">Alt matcher</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Samme designer, samme fargeprofil, samme kvalitet — fra jakke til varebil til fasadeskilt.
          </p>
        </div>

        <div class="bg-white rounded-3xl border border-border p-8 text-center hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <div class="w-14 h-14 rounded-2xl bg-emerald-100 flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-emerald-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-text mb-2">Rask levering</h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            Eget lager, eget verksted. Standard 2–3 uker, hasteordre etter avtale.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Stats bar -->
  <section class="py-16 bg-primary">
    <div class="mx-auto max-w-5xl px-4 lg:px-6">
      <div data-reveal-stagger class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <p class="text-3xl md:text-4xl font-extrabold text-white"><AnimatedCounter value="500" suffix="+" /></p>
          <p class="text-sm text-white/50 mt-1">Bedriftskunder</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-extrabold text-white"><AnimatedCounter value="6" /></p>
          <p class="text-sm text-white/50 mt-1">Premiummerker</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-extrabold text-white"><AnimatedCounter value="1" /></p>
          <p class="text-sm text-white/50 mt-1">Kontaktperson</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-extrabold text-white"><AnimatedCounter value="1" /></p>
          <p class="text-sm text-white/50 mt-1">Faktura</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Service overview -->
  <section class="py-24 md:py-32">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="max-w-2xl mb-16" data-reveal>
        <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-4">Tjenester</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-text">Alt du trenger, ett sted.</h2>
      </div>

      <div data-reveal-stagger class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <a href="/produkter" class="group bg-white rounded-3xl border border-border p-8 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <div class="flex items-start gap-5">
            <div class="w-12 h-12 rounded-2xl bg-blue-50 flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
              <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/></svg>
            </div>
            <div>
              <h3 class="text-lg font-bold text-text group-hover:text-primary transition-colors mb-1">Arbeidstøy og profilklær</h3>
              <p class="text-sm text-text-secondary leading-relaxed">Payper, L.Brador, Roly og flere. Tilpasset din bransje og ditt budsjett.</p>
            </div>
          </div>
        </a>

        <a href="/tjenester/tekstiltrykk" class="group bg-white rounded-3xl border border-border p-8 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <div class="flex items-start gap-5">
            <div class="w-12 h-12 rounded-2xl bg-emerald-50 flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
              <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.764m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42"/></svg>
            </div>
            <div>
              <h3 class="text-lg font-bold text-text group-hover:text-primary transition-colors mb-1">Tekstiltrykk og broderi</h3>
              <p class="text-sm text-text-secondary leading-relaxed">Screentrykk, DTF, transfer, sublimering og broderi. Vi velger riktig teknikk.</p>
            </div>
          </div>
        </a>

        <a href="/tjenester/foliering" class="group bg-white rounded-3xl border border-border p-8 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <div class="flex items-start gap-5">
            <div class="w-12 h-12 rounded-2xl bg-violet-50 flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
              <svg class="w-6 h-6 text-violet-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/></svg>
            </div>
            <div>
              <h3 class="text-lg font-bold text-text group-hover:text-primary transition-colors mb-1">Foliering og skilting</h3>
              <p class="text-sm text-text-secondary leading-relaxed">Biler, vinduer, fasader. Gjør hver overflate til en reklamekanal.</p>
            </div>
          </div>
        </a>

        <a href="/tjenester/storformat" class="group bg-white rounded-3xl border border-border p-8 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <div class="flex items-start gap-5">
            <div class="w-12 h-12 rounded-2xl bg-rose-50 flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
              <svg class="w-6 h-6 text-rose-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5a1.5 1.5 0 0 0 1.5-1.5V4.5a1.5 1.5 0 0 0-1.5-1.5H3.75a1.5 1.5 0 0 0-1.5 1.5v15a1.5 1.5 0 0 0 1.5 1.5Z"/></svg>
            </div>
            <div>
              <h3 class="text-lg font-bold text-text group-hover:text-primary transition-colors mb-1">Storformat og print</h3>
              <p class="text-sm text-text-secondary leading-relaxed">Bannere, rollups, fasadeskilt og messevegg i høy kvalitet.</p>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- 6. Contact form -->
  <section id="kontakt-bedrift" class="py-24 md:py-32 bg-bg-alt">
    <div class="mx-auto max-w-3xl px-4 lg:px-6">
      <div class="text-center mb-12" data-reveal>
        <h2 class="text-3xl md:text-4xl font-extrabold text-text mb-3">La oss snakke om din bedrift.</h2>
        <p class="text-lg text-text-secondary max-w-xl mx-auto">
          Fortell oss hva du trenger, så lager vi et skreddersydd tilbud. Svar innen én arbeidsdag.
        </p>
      </div>
      <div class="bg-white rounded-3xl border border-border p-8 md:p-10" data-reveal>
        <ContactForm formName="bedrift" showCompany={true} />
      </div>
    </div>
  </section>
</BaseLayout>
