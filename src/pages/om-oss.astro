---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';
import AnimatedCounter from '../components/AnimatedCounter.astro';

const shopUrl = 'https://butikk.percor.no';
---

<BaseLayout
  title="Om oss"
  description="Percor AS er din totalleverandør av arbeidstøy, profilklær, trykk, foliering og design. Eksklusiv norsk importør av Payper."
>
  <div class="mx-auto max-w-7xl px-4 lg:px-6">
    <Breadcrumbs items={[{ label: 'Om oss' }]} />
  </div>

  <!-- Hero -->
  <section class="relative bg-primary overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f1d2e] via-primary to-primary-light/60"></div>
      <div class="absolute top-1/3 left-1/4 w-[400px] h-[400px] bg-accent/8 rounded-full blur-[100px]"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 lg:px-6 py-20 md:py-28">
      <div class="max-w-3xl">
        <p data-reveal class="text-accent-light font-semibold text-sm uppercase tracking-widest mb-6">Om Percor</p>
        <h1 data-reveal class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-[1.1]">
          Vi gjør bedrifter<br />synlige.
        </h1>
        <p data-reveal class="mt-6 text-lg text-white/60 leading-relaxed max-w-xl">
          Fra et lite lager på Sætre til Norges mest komplette leverandør av arbeidstøy, profilklær, trykk og design.
        </p>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="relative -mt-8 z-10 mb-8">
    <div class="mx-auto max-w-4xl px-4 lg:px-6">
      <div data-reveal class="bg-white rounded-2xl border border-border shadow-lg p-6">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
          <div>
            <p class="text-3xl font-extrabold text-primary"><AnimatedCounter value="500" suffix="+" /></p>
            <p class="text-xs text-text-secondary mt-1">Produkter</p>
          </div>
          <div>
            <p class="text-3xl font-extrabold text-accent"><AnimatedCounter value="6" /></p>
            <p class="text-xs text-text-secondary mt-1">Merkevarer</p>
          </div>
          <div>
            <p class="text-3xl font-extrabold text-primary"><AnimatedCounter value="4" /></p>
            <p class="text-xs text-text-secondary mt-1">Fagområder</p>
          </div>
          <div>
            <p class="text-3xl font-extrabold text-accent"><AnimatedCounter value="1" /></p>
            <p class="text-xs text-text-secondary mt-1">Kontaktperson</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Our story -->
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <p data-reveal class="text-accent font-semibold text-sm uppercase tracking-widest mb-4">Vår historie</p>
          <h2 data-reveal class="text-3xl md:text-4xl font-extrabold text-text leading-tight mb-8">
            Fra lokal leverandør<br />til totalleverandør
          </h2>
          <div data-reveal class="space-y-5 text-text-secondary leading-relaxed">
            <p>
              Percor startet som en lokal leverandør av arbeidsklær. Gjennom årene har vi bygget sterke partnerskap med internasjonale merkevarer og blitt <strong class="text-text">eksklusiv norsk importør av Payper</strong> — et av Europas mest respekterte merker for arbeidstøy og profilklær.
            </p>
            <p>
              Men klær er bare starten. Kundene våre trengte også trykk, broderi, design, foliering og skilt. I stedet for å sende dem videre, bygget vi kompetansen selv. I dag gjør vi alt — under ett tak, på Åsveien 5 i Sætre.
            </p>
            <p>
              Vi betjener kunder over hele Norge — fra håndverksbedrifter og sportsklubber til store organisasjoner og offentlige virksomheter.
            </p>
          </div>
        </div>

        <!-- Contact card -->
        <div data-reveal="right">
          <div class="bg-bg-alt rounded-3xl p-8 lg:p-10">
            <h3 class="text-xl font-bold text-text mb-6">Finn oss</h3>
            <ul class="space-y-5">
              <li class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-text">Adresse</p>
                  <p class="text-text-secondary text-sm">Åsveien 5, 3475 Sætre</p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-text">E-post</p>
                  <a href="mailto:stein@percor.no" class="text-primary text-sm hover:underline">stein@percor.no</a>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-text">Telefon</p>
                  <a href="tel:+4790772409" class="text-primary text-sm hover:underline">907 72 409</a>
                </div>
              </li>
            </ul>
            <div class="mt-8 pt-6 border-t border-border">
              <p class="text-sm font-semibold text-text mb-2">Åpningstider</p>
              <div class="space-y-1.5 text-sm text-text-secondary">
                <div class="flex justify-between"><span>Mandag – Fredag</span><span class="font-medium text-text">08:00 – 16:00</span></div>
                <div class="flex justify-between"><span>Lørdag – Søndag</span><span class="text-text-light">Stengt</span></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-16 md:py-24 bg-bg-alt">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="text-center mb-14">
        <p data-reveal class="text-accent font-semibold text-sm uppercase tracking-widest mb-4">Våre verdier</p>
        <h2 data-reveal class="text-3xl md:text-4xl font-extrabold text-text">Det vi bygger på</h2>
      </div>
      <div data-reveal-stagger class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white rounded-2xl border border-border p-7 text-center hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200">
          <div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-text mb-2">Kvalitet</h3>
          <p class="text-sm text-text-secondary leading-relaxed">Vi velger kun merkevarer og materialer vi kan stå inne for. Kvalitet i alle ledd.</p>
        </div>
        <div class="bg-white rounded-2xl border border-border p-7 text-center hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200">
          <div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-text mb-2">Personlig service</h3>
          <p class="text-sm text-text-secondary leading-relaxed">Du snakker med mennesker som kjenner produktene og forstår behovene dine.</p>
        </div>
        <div class="bg-white rounded-2xl border border-border p-7 text-center hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200">
          <div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-text mb-2">Effektivitet</h3>
          <p class="text-sm text-text-secondary leading-relaxed">Fra bestilling til levering — vi holder det vi lover, innen den tiden vi avtaler.</p>
        </div>
        <div class="bg-white rounded-2xl border border-border p-7 text-center hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200">
          <div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12.75 3.03v.568c0 .334.148.65.405.864l1.068.89c.442.369.535 1.01.216 1.49l-.51.766a2.25 2.25 0 01-1.161.886l-.143.048a1.107 1.107 0 00-.57 1.664c.369.555.169 1.307-.427 1.605L9 13.125l.423 1.059a.956.956 0 01-1.652.928l-.679-.906a1.125 1.125 0 00-1.906.172L4.5 15.75l-.612.153M12.75 3.031a9 9 0 00-8.862 12.872M12.75 3.031a9 9 0 016.69 14.036m0 0l-.177-.529A2.25 2.25 0 0017.128 15H16.5l-.324-.324a1.453 1.453 0 00-2.328.377l-.036.073a1.586 1.586 0 01-.982.816l-.99.282c-.55.157-.894.702-.8 1.267l.073.438c.08.474.49.821.97.821.846 0 1.598.542 1.865 1.345l.215.643m5.276-3.67a9.012 9.012 0 01-5.276 3.67"/></svg>
          </div>
          <h3 class="text-lg font-bold text-text mb-2">Ansvar</h3>
          <p class="text-sm text-text-secondary leading-relaxed">Vi samarbeider med leverandører som deler vårt fokus på ansvarlig produksjon.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team teaser -->
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="max-w-3xl mx-auto text-center">
        <p data-reveal class="text-accent font-semibold text-sm uppercase tracking-widest mb-4">Teamet</p>
        <h2 data-reveal class="text-3xl md:text-4xl font-extrabold text-text mb-6">Menneskene bak Percor</h2>
        <p data-reveal class="text-lg text-text-secondary leading-relaxed mb-10">
          Hos oss finner du et engasjert team med bred kompetanse innen tekstil, trykk, design og kundeservice. Vi brenner for å hjelpe kundene våre med å se profesjonelle ut — enten det gjelder arbeidstøy på byggeplassen eller profilklær på messestand.
        </p>
        <div data-reveal class="flex flex-wrap justify-center gap-4">
          <a href="/kontakt" class="group inline-flex items-center gap-2 bg-primary text-white px-8 py-4 rounded-xl font-semibold hover:bg-primary-light transition-colors shadow-sm">
            Ta kontakt med oss
            <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href={shopUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-primary font-semibold hover:text-primary-light transition-colors">
            Eller besøk nettbutikken
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
