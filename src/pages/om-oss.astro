---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';

const shopUrl = 'https://butikk.percor.no';
---

<BaseLayout
  title="Om oss"
  description="Percor AS er din totalleverandør av arbeidstøy, profilklær, trykk, foliering og design. Eksklusiv norsk importør av Payper. Besøk oss på Åsveien 5, 3475 Sætre."
>
  <Breadcrumbs items={[{ label: 'Om oss' }]} />

  <!-- Hero -->
  <section class="relative bg-primary overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-gradient-to-br from-primary-lighter/20 to-transparent"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 lg:px-6 py-16 md:py-24 text-center">
      <p class="text-accent-light font-semibold text-sm uppercase tracking-wider mb-4">Om Percor</p>
      <h1 class="text-4xl md:text-5xl font-bold text-white">Din totalleverandør</h1>
      <p class="mt-4 text-lg md:text-xl text-dark-text-secondary max-w-2xl mx-auto">
        Arbeidstøy, profilklær, tekstiltrykk, foliering og grafisk design — alt under ett tak.
      </p>
    </div>
  </section>

  <!-- Hvem vi er -->
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="text-sm font-semibold text-accent uppercase tracking-wider mb-2">Hvem vi er</p>
          <h2 class="text-3xl md:text-4xl font-bold text-text mb-6">Percor AS</h2>
          <div class="space-y-4 text-text-secondary leading-relaxed">
            <p>
              Percor AS er en norsk importør og distributør av arbeidstøy, profilklær og verneutstyr. Vi holder til
              på <strong class="text-text">Åsveien 5 i Sætre (3475)</strong>, hvor vi har kontor, lager og
              produksjonslokaler samlet under ett tak.
            </p>
            <p>
              Vi tilbyr et komplett spekter av tjenester — fra tekstiltrykk, foliering og storformatprint til
              grafisk design. Uansett om du er en liten bedrift som trenger profilerte t-skjorter, eller en stor
              organisasjon med behov for komplett arbeidstøy, hjelper vi deg hele veien.
            </p>
            <p>
              Som <strong class="text-text">eksklusiv norsk importør av Payper</strong> kan vi tilby et bredt
              utvalg av italiensk kvalitetsklær til konkurransedyktige priser. I tillegg fører vi merkevarer som
              L.Brador, Roly, Zeus Sport, Skydda og Stamina.
            </p>
          </div>
        </div>
        <div class="bg-bg-alt rounded-xl p-8 lg:p-10">
          <h3 class="text-xl font-bold text-text mb-6">Kontaktinformasjon</h3>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z"/><circle cx="12" cy="11" r="3"/></svg>
              <div>
                <p class="font-semibold text-text">Adresse</p>
                <p class="text-text-secondary">Åsveien 5, 3475 Sætre</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              <div>
                <p class="font-semibold text-text">E-post</p>
                <a href="mailto:stein@percor.no" class="text-primary hover:underline">stein@percor.no</a>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              <div>
                <p class="font-semibold text-text">Telefon</p>
                <a href="tel:+4790772409" class="text-primary hover:underline">907 72 409</a>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Verdier -->
  <section class="py-16 md:py-24 bg-bg-alt">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="text-sm font-semibold text-accent uppercase tracking-wider mb-2">Våre verdier</p>
        <h2 class="text-3xl md:text-4xl font-bold text-text">Det vi står for</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white rounded-xl border border-border p-6 text-center">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-text mb-2">Kvalitet</h3>
          <p class="text-sm text-text-secondary leading-relaxed">Vi velger kun merkevarer og materialer vi kan stå inne for. Kvalitet i alle ledd.</p>
        </div>
        <div class="bg-white rounded-xl border border-border p-6 text-center">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-text mb-2">Personlig service</h3>
          <p class="text-sm text-text-secondary leading-relaxed">Vi tar oss tid til å forstå dine behov og leverer skreddersydde løsninger.</p>
        </div>
        <div class="bg-white rounded-xl border border-border p-6 text-center">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-text mb-2">Effektivitet</h3>
          <p class="text-sm text-text-secondary leading-relaxed">Rask levering og smidig prosess fra bestilling til ferdig produkt.</p>
        </div>
        <div class="bg-white rounded-xl border border-border p-6 text-center">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-text mb-2">Bærekraft</h3>
          <p class="text-sm text-text-secondary leading-relaxed">Vi jobber med leverandører som deler vårt fokus på ansvarlig produksjon.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Historikk & team -->
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 lg:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <p class="text-sm font-semibold text-accent uppercase tracking-wider mb-2">Vår historie</p>
          <h2 class="text-3xl md:text-4xl font-bold text-text mb-6">Fra lokal leverandør til totalleverandør</h2>
          <div class="space-y-4 text-text-secondary leading-relaxed">
            <p>
              Percor startet som en lokal leverandør av arbeidsklær og har gjennom årene vokst til å bli en
              totalleverandør av arbeidstøy, profilklær, trykk og design. Vi har bygget sterke partnerskap
              med internasjonale merkevarer og blitt eksklusiv norsk importør av det italienske kvalitetsmerket Payper.
            </p>
            <p>
              I dag betjener vi kunder over hele Norge — fra håndverksbedrifter og sportsklubber til større
              organisasjoner og offentlige virksomheter.
            </p>
          </div>
        </div>
        <div>
          <p class="text-sm font-semibold text-accent uppercase tracking-wider mb-2">Teamet</p>
          <h2 class="text-3xl md:text-4xl font-bold text-text mb-6">Menneskene bak Percor</h2>
          <div class="space-y-4 text-text-secondary leading-relaxed">
            <p>
              Hos Percor finner du et engasjert team med bred kompetanse innen tekstil, trykk, design og
              kundeservice. Vi brenner for å hjelpe kundene våre med å se profesjonelle ut — enten det gjelder
              arbeidstøy på byggeplassen eller profilklær på messestand.
            </p>
            <p>
              Ta gjerne kontakt med oss direkte — vi er alltid tilgjengelige for en prat om ditt neste prosjekt.
            </p>
          </div>
          <div class="mt-6">
            <a href="/kontakt" class="inline-flex items-center gap-2 bg-primary text-white px-6 py-3 rounded-lg font-semibold hover:bg-primary-light transition-colors">
              Ta kontakt
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-accent">
    <div class="mx-auto max-w-4xl px-4 lg:px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Klar for et samarbeid?</h2>
      <p class="text-lg text-white/90 mb-8 max-w-2xl mx-auto">
        Vi hjelper deg med alt fra arbeidstøy og profilklær til trykk og design. Ta kontakt for en uforpliktende prat.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/kontakt" class="inline-flex items-center gap-2 bg-white text-accent px-7 py-3.5 rounded-lg font-semibold hover:bg-white/90 transition-colors">
          Kontakt oss
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href={shopUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-white/20 text-white px-7 py-3.5 rounded-lg font-semibold hover:bg-white/30 transition-colors backdrop-blur-sm">
          Besøk nettbutikken
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
