<div class="container" style="max-width: 480px; padding: var(--spacing-3xl) var(--spacing-md);">
  <h1 class="text-center">Opprett konto</h1>

  {%- form 'create_customer' -%}
    {%- if form.errors -%}
      <div class="mb-lg" style="background: #FFEBEE; padding: var(--spacing-md); border-radius: var(--radius-sm); color: var(--color-error);">
        {{ form.errors | default_errors }}
      </div>
    {%- endif -%}

    <div class="two-col" style="gap: var(--spacing-md);">
      <div class="form-group">
        <label class="form-label" for="first-name">Fornavn</label>
        <input class="form-input" type="text" id="first-name" name="customer[first_name]" required autocomplete="given-name">
      </div>
      <div class="form-group">
        <label class="form-label" for="last-name">Etternavn</label>
        <input class="form-input" type="text" id="last-name" name="customer[last_name]" required autocomplete="family-name">
      </div>
    </div>

    <div class="form-group">
      <label class="form-label" for="reg-email">E-post</label>
      <input class="form-input" type="email" id="reg-email" name="customer[email]" required autocomplete="email">
    </div>

    <div class="form-group">
      <label class="form-label" for="reg-password">Passord</label>
      <input class="form-input" type="password" id="reg-password" name="customer[password]" required autocomplete="new-password">
    </div>

    <button type="submit" class="btn btn--primary btn--full">Opprett konto</button>

    <div class="text-center mt-lg">
      <span class="text-light">Har du allerede en konto?</span>
      <a href="/account/login">Logg inn</a>
    </div>
  {%- endform -%}
</div>
