<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gavekort | {{ shop.name }}</title>
  {{ 'percor-base.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
</head>
<body>
  <div class="container text-center" style="padding: var(--spacing-3xl) var(--spacing-md); max-width: 600px;">
    <h1>Gavekort fra {{ shop.name }}</h1>
    <p style="font-size: 1.5rem; font-weight: 700; margin: var(--spacing-xl) 0;">{{ gift_card.balance | money }}</p>

    <div style="background: var(--color-bg-light); padding: var(--spacing-xl); border-radius: var(--radius-md); margin: var(--spacing-xl) 0;">
      <p style="font-size: 0.875rem; color: var(--color-text-light); margin-bottom: var(--spacing-sm);">Gavekortkode:</p>
      <p style="font-size: 1.5rem; font-weight: 700; letter-spacing: 2px;">{{ gift_card.code | format_code }}</p>
    </div>

    {%- if gift_card.expired -%}
      <p style="color: var(--color-error);">Dette gavekortet er utløpt.</p>
    {%- endif -%}

    {%- if gift_card.enabled -%}
      <a href="{{ shop.url }}" class="btn btn--primary">Bruk gavekort i butikken</a>
    {%- endif -%}
  </div>
</body>
</html>
