<section class="section" aria-label="Produktkategorier">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <div class="section-header">
        <h2>{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="section-header__subtitle">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="category-grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link }}" class="category-card" {{ block.shopify_attributes }}>
          <div class="category-card__bg">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 600 }}"
                alt="{{ block.settings.title }}"
                width="600"
                height="400"
                loading="lazy"
              >
            {%- endif -%}
          </div>
          <div class="category-card__overlay"></div>
          <div class="category-card__content">
            <h3 class="category-card__title">{{ block.settings.title }}</h3>
            <p class="category-card__desc">{{ block.settings.description }}</p>
            <span class="category-card__link">{{ block.settings.link_text | default: 'Se utvalget' }}</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kategorikort",
  "tag": "section",
  "class": "category-grid-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Undertekst"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Kategori",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bilde",
          "info": "Anbefalt: 600x400px"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Tittel",
          "default": "Kategori"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Kort beskrivelse",
          "default": "Kort beskrivelse"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lenke"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Lenketekst",
          "default": "Se utvalget"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kategorikort",
      "blocks": [
        { "type": "category", "settings": { "title": "Arbeidstøy", "description": "Fra Payper, L.Brador og flere", "link_text": "Se utvalget" } },
        { "type": "category", "settings": { "title": "Profilklær", "description": "Klær med din logo fra 50 stk", "link_text": "Se utvalget" } },
        { "type": "category", "settings": { "title": "Verneutstyr", "description": "HMS og sikkerhet fra Skydda", "link_text": "Se utvalget" } },
        { "type": "category", "settings": { "title": "Sport & Fritid", "description": "Zeus Sport Italia — drakter og utstyr", "link_text": "Se utvalget" } },
        { "type": "category", "settings": { "title": "Gaveartikler", "description": "Flasker, vesker, penner og mer", "link_text": "Se utvalget" } },
        { "type": "category", "settings": { "title": "Trykk & Design", "description": "Broderi, foliering, bannere og mer", "link_text": "Se tjenester" } }
      ]
    }
  ]
}
{% endschema %}
