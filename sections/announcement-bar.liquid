{%- if section.settings.show_announcement -%}
  <div class="announcement-bar" role="complementary" aria-label="Informasjon">
    <div class="announcement-bar__content container">
      {%- for block in section.blocks -%}
        <span {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}">{{ block.settings.text }}</a>
          {%- else -%}
            {{ block.settings.text }}
          {%- endif -%}
        </span>
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "section",
  "class": "announcement-bar-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Vis announcement bar",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Melding",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Tekst",
          "default": "📦 Gratis frakt over 999 kr"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lenke (valgfritt)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": [
        { "type": "message", "settings": { "text": "📦 Gratis frakt over 999 kr" } },
        { "type": "message", "settings": { "text": "📍 Besøk vår butikk på Sætre" } },
        { "type": "message", "settings": { "text": "📞 Ring 907 72 409" } }
      ]
    }
  ]
}
{% endschema %}
