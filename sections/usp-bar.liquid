<section class="usp-bar section--sm" aria-label="Våre fordeler">
  <div class="container">
    <div class="usp-bar__grid">
      {%- for block in section.blocks -%}
        <div class="usp-bar__item" {{ block.shopify_attributes }}>
          <div class="usp-bar__icon">
            {%- case block.settings.icon -%}
              {%- when 'factory' -%}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/></svg>
              {%- when 'flag' -%}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
              {%- when 'layers' -%}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
              {%- when 'truck' -%}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {%- else -%}
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            {%- endcase -%}
          </div>
          <span class="usp-bar__title">{{ block.settings.title }}</span>
          <span class="usp-bar__text">{{ block.settings.text }}</span>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "USP-bar",
  "tag": "section",
  "class": "usp-bar-section",
  "max_blocks": 4,
  "settings": [],
  "blocks": [
    {
      "type": "usp",
      "name": "USP-punkt",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Ikon",
          "options": [
            { "value": "factory", "label": "Fabrikk" },
            { "value": "flag", "label": "Flagg" },
            { "value": "layers", "label": "Lag/alt-i-ett" },
            { "value": "truck", "label": "Lastebil/frakt" },
            { "value": "check", "label": "Hake" }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Tittel",
          "default": "Fordel"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Beskrivelse",
          "default": "Kort beskrivelse"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "USP-bar",
      "blocks": [
        { "type": "usp", "settings": { "icon": "factory", "title": "Direkte import", "text": "Gode priser" } },
        { "type": "usp", "settings": { "icon": "flag", "title": "Eksklusiv Payper", "text": "Kun hos Percor" } },
        { "type": "usp", "settings": { "icon": "layers", "title": "Alt under ett tak", "text": "Varer + trykk + design" } },
        { "type": "usp", "settings": { "icon": "truck", "title": "Rask levering", "text": "Fra europeiske lagre" } }
      ]
    }
  ]
}
{% endschema %}
