<div class="container" style="padding: var(--spacing-2xl) var(--spacing-md) var(--spacing-3xl);">
  <h1>Handlekurv</h1>

  {%- if cart.item_count > 0 -%}
    <form action="/cart" method="post">
      <table style="width: 100%; border-collapse: collapse; margin: var(--spacing-xl) 0;">
        <thead>
          <tr style="border-bottom: 2px solid var(--color-border); text-align: left;">
            <th style="padding: var(--spacing-md) 0; font-size: 0.875rem;">Produkt</th>
            <th style="padding: var(--spacing-md) 0; font-size: 0.875rem;">Pris</th>
            <th style="padding: var(--spacing-md) 0; font-size: 0.875rem; width: 100px;">Antall</th>
            <th style="padding: var(--spacing-md) 0; font-size: 0.875rem; text-align: right;">Totalt</th>
          </tr>
        </thead>
        <tbody>
          {%- for item in cart.items -%}
            <tr style="border-bottom: 1px solid var(--color-border);">
              <td style="padding: var(--spacing-md) 0;">
                <div style="display: flex; gap: var(--spacing-md); align-items: center;">
                  {%- if item.image -%}
                    <img src="{{ item.image | image_url: width: 100 }}" alt="{{ item.title }}" width="80" height="80" style="border-radius: var(--radius-sm); object-fit: cover;">
                  {%- endif -%}
                  <div>
                    <a href="{{ item.url }}" style="font-weight: 500; color: var(--color-text);">{{ item.product.title }}</a>
                    {%- unless item.variant.title == 'Default Title' -%}
                      <p class="text-light" style="font-size: 0.8125rem;">{{ item.variant.title }}</p>
                    {%- endunless -%}
                  </div>
                </div>
              </td>
              <td style="padding: var(--spacing-md) 0;">{{ item.price | money }}</td>
              <td style="padding: var(--spacing-md) 0;">
                <input
                  type="number"
                  name="updates[]"
                  value="{{ item.quantity }}"
                  min="0"
                  class="form-input"
                  style="width: 70px; padding: var(--spacing-sm); text-align: center;"
                  aria-label="Antall {{ item.product.title }}"
                >
              </td>
              <td style="padding: var(--spacing-md) 0; text-align: right; font-weight: 600;">
                {{ item.line_price | money }}
              </td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>

      <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: var(--spacing-md); margin-top: var(--spacing-lg);">
        <button type="submit" name="update" class="btn btn--secondary btn--sm">Oppdater handlekurv</button>
        <div style="text-align: right;">
          <p style="font-size: 1.25rem; font-weight: 700; margin-bottom: var(--spacing-sm);">
            Totalt: {{ cart.total_price | money }}
          </p>
          <p class="text-light" style="font-size: 0.8125rem; margin-bottom: var(--spacing-md);">Frakt beregnes i kassen</p>
          <button type="submit" name="checkout" class="btn btn--primary btn--lg">Gå til kassen</button>
        </div>
      </div>
    </form>

  {%- else -%}
    <div class="text-center" style="padding: var(--spacing-3xl) 0;">
      <p style="font-size: 1.125rem; margin-bottom: var(--spacing-lg);">Handlekurven din er tom.</p>
      <a href="/collections/all" class="btn btn--primary">Se produkter</a>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Handlekurv",
  "tag": "section",
  "settings": []
}
{% endschema %}
