{% render 'breadcrumbs' %}
{% render 'structured-data' %}

<div class="container" style="padding: var(--spacing-xl) var(--spacing-md) var(--spacing-3xl);">
  <div class="two-col two-col--60-40">
    {%- comment -%} Left: Product Images {%- endcomment -%}
    <div>
      <div class="product-gallery">
        <div class="product-gallery__main" style="border-radius: var(--radius-md); overflow: hidden; background: var(--color-bg-light); margin-bottom: var(--spacing-md);">
          {%- if product.featured_image -%}
            <img
              id="product-main-image"
              src="{{ product.featured_image | image_url: width: 1200 }}"
              alt="{{ product.featured_image.alt | default: product.title | escape }}"
              width="1200"
              height="1200"
              loading="eager"
              style="width: 100%; height: auto; cursor: zoom-in;"
            >
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>

        {%- if product.images.size > 1 -%}
          <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(80px, 1fr)); gap: var(--spacing-sm);">
            {%- for image in product.images -%}
              <button
                type="button"
                style="border: 2px solid {% if forloop.first %}var(--color-primary){% else %}var(--color-border){% endif %}; border-radius: var(--radius-sm); overflow: hidden; padding: 0; background: var(--color-bg-light); cursor: pointer; aspect-ratio: 1;"
                onclick="document.getElementById('product-main-image').src='{{ image | image_url: width: 1200 }}'; document.getElementById('product-main-image').alt='{{ image.alt | escape }}'; this.parentElement.querySelectorAll('button').forEach(b => b.style.borderColor='var(--color-border)'); this.style.borderColor='var(--color-primary)';"
                aria-label="Vis bilde {{ forloop.index }}"
              >
                <img
                  src="{{ image | image_url: width: 160 }}"
                  alt="{{ image.alt | default: product.title | escape }}"
                  width="80"
                  height="80"
                  loading="lazy"
                  style="width: 100%; height: 100%; object-fit: cover;"
                >
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Right: Product Info {%- endcomment -%}
    <div>
      {%- if product.vendor != blank -%}
        <p style="margin-bottom: var(--spacing-xs);">
          <a href="/collections/merkevare-{{ product.vendor | handleize }}" style="font-size: 0.875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: var(--color-text-light);">
            {{ product.vendor }}
          </a>
        </p>
      {%- endif -%}

      <h1 style="margin-bottom: var(--spacing-md);">{{ product.title }}</h1>

      <div style="font-size: 1.5rem; font-weight: 700; margin-bottom: var(--spacing-lg);">
        {%- if product.price_varies -%}
          <span>Fra {{ product.price_min | money }}</span>
        {%- else -%}
          <span {% if product.compare_at_price > product.price %}style="color: var(--color-error);"{% endif %}>
            {{ product.price | money }}
          </span>
          {%- if product.compare_at_price > product.price -%}
            <s style="font-size: 1rem; color: var(--color-text-light); margin-left: var(--spacing-sm); font-weight: 400;">{{ product.compare_at_price | money }}</s>
          {%- endif -%}
        {%- endif -%}
      </div>

      {%- if product.description != blank -%}
        <div style="margin-bottom: var(--spacing-xl); color: var(--color-text-light); line-height: 1.7;">
          {{ product.description | strip_html | truncatewords: 30 }}
        </div>
      {%- endif -%}

      {%- comment -%} Product Form {%- endcomment -%}
      {%- form 'product', product -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

        {%- for option in product.options_with_values -%}
          <div class="form-group">
            <label class="form-label" for="option-{{ option.name | handleize }}">{{ option.name }}</label>
            <select class="form-select" id="option-{{ option.name | handleize }}" name="options[{{ option.name }}]">
              {%- for value in option.values -%}
                <option value="{{ value }}" {% if option.selected_value == value %}selected{% endif %}>
                  {{ value }}
                </option>
              {%- endfor -%}
            </select>
          </div>
        {%- endfor -%}

        <p style="margin-bottom: var(--spacing-sm);">
          <a href="/pages/storrelsesguide" style="font-size: 0.875rem;">Størrelsesguide →</a>
        </p>

        <div class="form-group">
          <label class="form-label" for="quantity">Antall</label>
          <input
            class="form-input"
            type="number"
            id="quantity"
            name="quantity"
            value="1"
            min="1"
            style="max-width: 100px;"
          >
        </div>

        <button type="submit" class="btn btn--primary btn--full btn--lg" {% unless product.available %}disabled{% endunless %}>
          {%- if product.available -%}
            Legg i handlekurv
          {%- else -%}
            Utsolgt
          {%- endif -%}
        </button>
      {%- endform -%}

      {%- comment -%} Secondary CTA {%- endcomment -%}
      <a
        href="/pages/kontakt?product={{ product.title | url_encode }}"
        class="btn btn--secondary btn--full mt-md"
      >
        Be om tilbud med trykk
      </a>

      {%- comment -%} Quick info {%- endcomment -%}
      <div style="margin-top: var(--spacing-xl); padding-top: var(--spacing-lg); border-top: 1px solid var(--color-border);">
        {%- if product.available -%}
          <p style="display: flex; align-items: center; gap: var(--spacing-sm); font-size: 0.875rem; color: var(--color-success); margin-bottom: var(--spacing-sm);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            På lager
          </p>
        {%- endif -%}
        <p style="display: flex; align-items: center; gap: var(--spacing-sm); font-size: 0.875rem; color: var(--color-text-light); margin-bottom: var(--spacing-sm);">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          Fri frakt over 999 kr
        </p>
        <p style="display: flex; align-items: center; gap: var(--spacing-sm); font-size: 0.875rem; color: var(--color-text-light);">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/></svg>
          Henting i butikk — Åsveien 5, Sætre
        </p>
      </div>
    </div>
  </div>

  {%- comment -%} Product Tabs {%- endcomment -%}
  <div style="margin-top: var(--spacing-2xl);">
    <div class="tabs__nav" role="tablist">
      <button class="tabs__tab tabs__tab--active" role="tab" aria-selected="true" data-tab="beskrivelse" onclick="switchTab(this, 'beskrivelse')">Beskrivelse</button>
      <button class="tabs__tab" role="tab" aria-selected="false" data-tab="spesifikasjoner" onclick="switchTab(this, 'spesifikasjoner')">Spesifikasjoner</button>
      <button class="tabs__tab" role="tab" aria-selected="false" data-tab="levering" onclick="switchTab(this, 'levering')">Levering & retur</button>
      <button class="tabs__tab" role="tab" aria-selected="false" data-tab="trykk" onclick="switchTab(this, 'trykk')">Trykk & profilering</button>
    </div>

    <div class="tabs__panel tabs__panel--active" id="tab-beskrivelse" role="tabpanel">
      <div class="page-content" style="padding-bottom: 0;">
        {{ product.description }}
      </div>
    </div>

    <div class="tabs__panel" id="tab-spesifikasjoner" role="tabpanel">
      <table style="width: 100%; max-width: 600px; border-collapse: collapse;">
        {%- if product.vendor != blank -%}
          <tr style="border-bottom: 1px solid var(--color-border);">
            <td style="padding: var(--spacing-sm) 0; font-weight: 600; width: 40%;">Merkevare</td>
            <td style="padding: var(--spacing-sm) 0;">{{ product.vendor }}</td>
          </tr>
        {%- endif -%}
        {%- if product.type != blank -%}
          <tr style="border-bottom: 1px solid var(--color-border);">
            <td style="padding: var(--spacing-sm) 0; font-weight: 600;">Type</td>
            <td style="padding: var(--spacing-sm) 0;">{{ product.type }}</td>
          </tr>
        {%- endif -%}
        <tr style="border-bottom: 1px solid var(--color-border);">
          <td style="padding: var(--spacing-sm) 0; font-weight: 600;">SKU</td>
          <td style="padding: var(--spacing-sm) 0;">{{ product.selected_or_first_available_variant.sku | default: '—' }}</td>
        </tr>
        {%- for option in product.options_with_values -%}
          <tr style="border-bottom: 1px solid var(--color-border);">
            <td style="padding: var(--spacing-sm) 0; font-weight: 600;">{{ option.name }}</td>
            <td style="padding: var(--spacing-sm) 0;">{{ option.values | join: ', ' }}</td>
          </tr>
        {%- endfor -%}
        {%- if product.tags.size > 0 -%}
          <tr style="border-bottom: 1px solid var(--color-border);">
            <td style="padding: var(--spacing-sm) 0; font-weight: 600;">Egenskaper</td>
            <td style="padding: var(--spacing-sm) 0;">{{ product.tags | join: ', ' }}</td>
          </tr>
        {%- endif -%}
      </table>
    </div>

    <div class="tabs__panel" id="tab-levering" role="tabpanel">
      <h3>Frakt</h3>
      <ul>
        <li>Gratis frakt på ordrer over 999 kr inkl. MVA</li>
        <li>Standard frakt med Posten/Bring Servicepakke</li>
        <li>Leveringstid: 1–3 virkedager etter forsendelse</li>
        <li>Henting i butikk: Gratis — Åsveien 5, 3475 Sætre</li>
      </ul>
      <h3>Retur</h3>
      <ul>
        <li>14 dagers angrerett for privatpersoner</li>
        <li>Varer med trykk/broderi kan normalt ikke returneres</li>
        <li>Varene må returneres ubrukt og i originalemballasje</li>
      </ul>
      <p><a href="/pages/frakt-og-levering">Les mer om frakt og levering →</a></p>
    </div>

    <div class="tabs__panel" id="tab-trykk" role="tabpanel">
      <h3>Dette produktet kan leveres med din logo</h3>
      <p>Vi tilbyr flere trykkmetoder tilpasset dette produktet:</p>
      <ul>
        <li><strong>Broderi</strong> — Holdbart og eksklusivt, perfekt for daglig bruk</li>
        <li><strong>Screentrykk</strong> — Kostnadseffektivt ved større opplag</li>
        <li><strong>Transfertrykk</strong> — Fleksibelt for detaljerte motiver</li>
        <li><strong>DTF-trykk</strong> — Fotokvalitet på tekstil</li>
      </ul>
      <p>
        <a href="/pages/kontakt?product={{ product.title | url_encode }}" class="btn btn--primary mt-md">
          Be om tilbud med trykk
        </a>
      </p>
      <p class="mt-md"><a href="/pages/trykk-og-design">Les mer om våre trykktjenester →</a></p>
    </div>
  </div>

  {%- comment -%} Related Products {%- endcomment -%}
  {%- if product.collections.first.products.size > 1 -%}
    <div style="margin-top: var(--spacing-3xl);">
      <h2>Relaterte produkter</h2>
      <div class="product-grid mt-lg">
        {%- for related_product in product.collections.first.products limit: 4 -%}
          {%- unless related_product.id == product.id -%}
            {% render 'product-card', product: related_product %}
          {%- endunless -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</div>

<script>
function switchTab(btn, tabId) {
  document.querySelectorAll('.tabs__tab').forEach(t => {
    t.classList.remove('tabs__tab--active');
    t.setAttribute('aria-selected', 'false');
  });
  document.querySelectorAll('.tabs__panel').forEach(p => p.classList.remove('tabs__panel--active'));
  btn.classList.add('tabs__tab--active');
  btn.setAttribute('aria-selected', 'true');
  document.getElementById('tab-' + tabId).classList.add('tabs__panel--active');
}
</script>

{% schema %}
{
  "name": "Produktside",
  "tag": "section",
  "settings": []
}
{% endschema %}
