<section class="section section--bg-light" aria-label="Våre merkevarer">
  <div class="container">
    <div class="section-header">
      <h2>{{ section.settings.heading | default: 'Merkevarer vi er stolte av' }}</h2>
    </div>

    <div class="brand-grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link }}" class="brand-grid__item" {{ block.shopify_attributes }} aria-label="{{ block.settings.name }}">
          {%- if block.settings.logo != blank -%}
            <img
              src="{{ block.settings.logo | image_url: width: 200 }}"
              alt="{{ block.settings.name }}"
              width="120"
              height="60"
              loading="lazy"
            >
          {%- else -%}
            <span style="display: block; text-align: center; font-weight: 700; font-size: 0.875rem; color: var(--color-text-light);">
              {{ block.settings.name }}
            </span>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>

    {%- if section.settings.subtext != blank -%}
      <p class="text-center text-light mt-xl" style="max-width: 640px; margin-left: auto; margin-right: auto;">
        {{ section.settings.subtext }}
        {%- if section.settings.subtext_link != blank and section.settings.subtext_link_text != blank -%}
          <br><a href="{{ section.settings.subtext_link }}">{{ section.settings.subtext_link_text }}</a>
        {%- endif -%}
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Merkevare-showcase",
  "tag": "section",
  "class": "brand-showcase-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Merkevarer vi er stolte av"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Undertekst",
      "default": "Percor er eksklusiv norsk forhandler av Payper — Italias ledende produsent av arbeidstøy med over 50 000 m² fabrikkareal."
    },
    {
      "type": "url",
      "id": "subtext_link",
      "label": "Undertekst lenke"
    },
    {
      "type": "text",
      "id": "subtext_link_text",
      "label": "Undertekst lenketekst",
      "default": "Les mer om Payper →"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Merkevare",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Merkenavn",
          "default": "Merkevare"
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lenke til merkevare"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Merkevare-showcase",
      "blocks": [
        { "type": "brand", "settings": { "name": "Payper" } },
        { "type": "brand", "settings": { "name": "L.Brador" } },
        { "type": "brand", "settings": { "name": "Roly" } },
        { "type": "brand", "settings": { "name": "Zeus Sport" } },
        { "type": "brand", "settings": { "name": "Skydda" } },
        { "type": "brand", "settings": { "name": "Stamina" } }
      ]
    }
  ]
}
{% endschema %}
