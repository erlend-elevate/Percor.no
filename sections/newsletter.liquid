<section class="section section--bg-light" aria-label="Nyhetsbrev">
  <div class="container">
    <div class="newsletter">
      <h2>{{ section.settings.heading | default: 'Få tilbud og nyheter rett i innboksen' }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="section-header__subtitle mb-lg">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- form 'customer', id: 'newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="nyhetsbrev">
        <div class="newsletter__form">
          <input
            type="email"
            name="contact[email]"
            class="newsletter__input"
            placeholder="Din e-postadresse"
            required
            aria-label="E-postadresse"
            autocomplete="email"
          >
          <button type="submit" class="btn btn--primary">
            {{ section.settings.button_text | default: 'Meld meg på' }}
          </button>
        </div>

        {%- if form.posted_successfully? -%}
          <p class="mt-md" style="color: var(--color-success); font-weight: 500;">
            Takk for påmeldingen! Du hører snart fra oss.
          </p>
        {%- endif -%}

        {%- if form.errors -%}
          <p class="mt-md" style="color: var(--color-error);">
            {{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}
          </p>
        {%- endif -%}
      {%- endform -%}

      {%- if section.settings.disclaimer != blank -%}
        <p class="newsletter__disclaimer">{{ section.settings.disclaimer }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nyhetsbrev",
  "tag": "section",
  "class": "newsletter-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Få tilbud og nyheter rett i innboksen"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Undertekst",
      "default": "Meld deg på vårt nyhetsbrev og vær først ute med nye kolleksjoner, kampanjer og tips om arbeidstøy og profilering."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Knapptekst",
      "default": "Meld meg på"
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Disclaimer-tekst",
      "default": "Vi sender maks 2 nyhetsbrev per måned. Du kan melde deg av når som helst."
    }
  ],
  "presets": [
    {
      "name": "Nyhetsbrev"
    }
  ]
}
{% endschema %}
