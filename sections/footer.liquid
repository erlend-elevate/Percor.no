<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="site-footer__grid">
      {%- comment -%} Brand column {%- endcomment -%}
      <div class="site-footer__brand">
        <div class="site-footer__logo">
          {%- if section.settings.logo != blank -%}
            <img
              src="{{ section.settings.logo | image_url: width: 180 }}"
              alt="{{ shop.name }}"
              width="180"
              height="{{ 180 | divided_by: section.settings.logo.aspect_ratio | round }}"
              loading="lazy"
            >
          {%- else -%}
            <span style="font-size: 1.5rem; font-weight: 700; color: var(--color-text-on-dark); letter-spacing: 1px;">PERCOR</span>
          {%- endif -%}
        </div>
        <p>{{ section.settings.description | default: 'Din totalleverandør av arbeidstøy, profilklær og trykk.' }}</p>

        <div class="site-footer__social">
          {%- if section.settings.social_facebook != blank -%}
            <a href="{{ section.settings.social_facebook }}" aria-label="Facebook" target="_blank" rel="noopener">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.social_instagram != blank -%}
            <a href="{{ section.settings.social_instagram }}" aria-label="Instagram" target="_blank" rel="noopener">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Link columns {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'link_list' -%}
            <div {{ block.shopify_attributes }}>
              <h4>{{ block.settings.heading }}</h4>
              <ul class="site-footer__links">
                {%- for link in linklists[block.settings.menu].links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            </div>

          {%- when 'contact' -%}
            <div {{ block.shopify_attributes }}>
              <h4>{{ block.settings.heading | default: 'Kontakt' }}</h4>
              <div class="site-footer__contact-info">
                {{ block.settings.content }}
              </div>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    {%- comment -%} Bottom bar {%- endcomment -%}
    <div class="site-footer__bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}{% if section.settings.org_nr != blank %} | Org.nr: {{ section.settings.org_nr }}{% endif %}</span>
      <span>Alle priser er inkl. MVA med mindre annet er oppgitt</span>
      <div class="site-footer__payments">
        {%- if section.settings.show_payment_icons -%}
          {{ shop.enabled_payment_types | payment_type_svg_tag }}
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "class": "footer-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo (lys versjon)"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Beskrivelse",
      "default": "Din totalleverandør av arbeidstøy, profilklær og trykk."
    },
    {
      "type": "text",
      "id": "org_nr",
      "label": "Organisasjonsnummer"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook-URL"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram-URL"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Vis betalingsikoner",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Lenkeliste",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Overskrift",
          "default": "Lenker"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Meny"
        }
      ]
    },
    {
      "type": "contact",
      "name": "Kontaktinfo",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Overskrift",
          "default": "Kontakt"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Kontaktinformasjon",
          "default": "<p>Percor AS<br>Åsveien 5, 3475 Sætre<br><a href='mailto:stein@percor.no'>stein@percor.no</a><br><a href='tel:+4790772409'>907 72 409</a></p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "link_list", "settings": { "heading": "Om Percor" } },
        { "type": "link_list", "settings": { "heading": "Kundeservice" } },
        { "type": "link_list", "settings": { "heading": "Kategorier" } },
        { "type": "contact", "settings": { "heading": "Kontakt" } }
      ]
    }
  ]
}
{% endschema %}
