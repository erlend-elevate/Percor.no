{% render 'breadcrumbs' %}

<div class="container" style="padding: var(--spacing-2xl) var(--spacing-md) var(--spacing-3xl);">
  <div class="page-header">
    <h1>Alle kategorier</h1>
  </div>

  <div class="category-grid">
    {%- for collection in collections -%}
      {%- unless collection.handle == 'all' or collection.handle == 'frontpage' -%}
        <a href="{{ collection.url }}" class="category-card">
          <div class="category-card__bg">
            {%- if collection.image -%}
              <img
                src="{{ collection.image | image_url: width: 600 }}"
                alt="{{ collection.title }}"
                width="600"
                height="400"
                loading="lazy"
              >
            {%- endif -%}
          </div>
          <div class="category-card__overlay"></div>
          <div class="category-card__content">
            <h2 class="category-card__title">{{ collection.title }}</h2>
            <span class="category-card__desc">{{ collection.products_count }} produkter</span>
          </div>
        </a>
      {%- endunless -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Alle kategorier",
  "tag": "section",
  "settings": []
}
{% endschema %}
