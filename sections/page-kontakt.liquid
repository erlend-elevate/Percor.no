{% render 'breadcrumbs' %}

<div class="container">
  <div class="page-header">
    <h1>Kontakt oss</h1>
  </div>

  <div class="contact-layout">
    {%- comment -%} Left: Contact info {%- endcomment -%}
    <div>
      <div class="contact-info__item">
        <svg class="contact-info__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <div>
          <strong>Percor AS</strong><br>
          Åsveien 5, 3475 Sætre
        </div>
      </div>

      <div class="contact-info__item">
        <svg class="contact-info__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        <div>
          <a href="mailto:stein@percor.no">stein@percor.no</a>
        </div>
      </div>

      <div class="contact-info__item">
        <svg class="contact-info__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <div>
          <a href="tel:+4790772409">907 72 409</a>
        </div>
      </div>

      <div class="contact-info__item">
        <svg class="contact-info__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <div>
          <strong>Åpningstider butikk:</strong><br>
          Mandag–fredag: 08:00–16:00<br>
          Lørdager og ettermiddager: Etter avtale
        </div>
      </div>

      <div class="contact-map">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2000!2d10.5!3d59.7!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2z!5e0!3m2!1sno!2sno!4v1"
          width="100%"
          height="300"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Percor AS på kart"
        ></iframe>
        <p class="text-light mt-sm" style="font-size: 0.8125rem;">
          Kartvisningen er omtrentlig. Søk opp «Åsveien 5, 3475 Sætre» for nøyaktig plassering.
        </p>
      </div>
    </div>

    {%- comment -%} Right: Contact form {%- endcomment -%}
    <div>
      <h2>Send oss en henvendelse</h2>

      {%- form 'contact', id: 'contact-form' -%}
        {%- if form.posted_successfully? -%}
          <div class="mb-lg" style="background: #E8F5E9; padding: var(--spacing-md); border-radius: var(--radius-sm); color: var(--color-success);">
            <strong>Takk for din henvendelse!</strong> Vi svarer normalt innen én virkedag.
          </div>
        {%- endif -%}

        {%- if form.errors -%}
          <div class="mb-lg" style="background: #FFEBEE; padding: var(--spacing-md); border-radius: var(--radius-sm); color: var(--color-error);">
            <strong>Vennligst rett opp følgende:</strong>
            <ul>
              {%- for field in form.errors -%}
                <li>{{ form.errors.translated_fields[field] }} {{ form.errors.messages[field] }}</li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}

        <div class="form-group">
          <label class="form-label" for="contact-name">Navn *</label>
          <input class="form-input" type="text" id="contact-name" name="contact[name]" required>
        </div>

        <div class="form-group">
          <label class="form-label" for="contact-email">E-post *</label>
          <input class="form-input" type="email" id="contact-email" name="contact[email]" required autocomplete="email">
        </div>

        <div class="form-group">
          <label class="form-label" for="contact-phone">Telefon</label>
          <input class="form-input" type="tel" id="contact-phone" name="contact[phone]" autocomplete="tel">
        </div>

        <div class="form-group">
          <label class="form-label" for="contact-company">Bedrift</label>
          <input class="form-input" type="text" id="contact-company" name="contact[company]" autocomplete="organization">
        </div>

        <div class="form-group">
          <label class="form-label" for="contact-subject">Emne *</label>
          <select class="form-select" id="contact-subject" name="contact[subject]" required>
            <option value="">Velg emne...</option>
            <option value="Generell henvendelse">Generell henvendelse</option>
            <option value="Tilbud — arbeidstøy">Be om tilbud — arbeidstøy</option>
            <option value="Tilbud — profilklær med trykk">Be om tilbud — profilklær med trykk</option>
            <option value="Tilbud — foliering">Be om tilbud — foliering</option>
            <option value="Tilbud — gaveartikler">Be om tilbud — gaveartikler</option>
            <option value="Tilbud — grafisk design">Be om tilbud — grafisk design</option>
            <option value="Reklamasjon / retur">Reklamasjon / retur</option>
            <option value="Bedriftskunde">Bedriftskunde</option>
            <option value="Annet">Annet</option>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label" for="contact-message">Melding *</label>
          <textarea class="form-textarea" id="contact-message" name="contact[body]" rows="6" required></textarea>
        </div>

        <button type="submit" class="btn btn--primary btn--full">Send henvendelse</button>
        <p class="text-light mt-md" style="font-size: 0.8125rem;">Vi svarer normalt innen én virkedag.</p>
      {%- endform -%}
    </div>
  </div>
</div>

<div style="padding-bottom: var(--spacing-3xl);"></div>

{% schema %}
{
  "name": "Kontakt",
  "settings": []
}
{% endschema %}
