<div class="container" style="padding: var(--spacing-2xl) var(--spacing-md) var(--spacing-3xl);">
  <div class="page-header">
    <h1>Søk</h1>
  </div>

  <form action="/search" method="get" role="search" style="max-width: 600px; margin-bottom: var(--spacing-2xl);">
    <div style="display: flex; gap: var(--spacing-sm);">
      <input
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        class="form-input"
        placeholder="Søk etter produkter, merkevarer..."
        aria-label="Søk"
      >
      <button type="submit" class="btn btn--primary">Søk</button>
    </div>
  </form>

  {%- if search.performed -%}
    {%- if search.results.size > 0 -%}
      <p class="mb-lg">{{ search.results_count }} resultater for «{{ search.terms }}»</p>
      <div class="product-grid">
        {%- for result in search.results -%}
          {%- if result.object_type == 'product' -%}
            {% render 'product-card', product: result %}
          {%- else -%}
            <div class="card">
              <div class="card__body">
                <h3 class="card__title">
                  <a href="{{ result.url }}" style="color: inherit;">{{ result.title }}</a>
                </h3>
                <p class="card__text">{{ result.content | strip_html | truncatewords: 20 }}</p>
                <a href="{{ result.url }}" class="card__link">Les mer</a>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="text-center" style="padding: var(--spacing-2xl) 0;">
        <p>Ingen resultater for «{{ search.terms }}».</p>
        <p class="text-light mt-md">Prøv et annet søkeord, eller <a href="/collections/all">se alle produkter</a>.</p>
      </div>
    {%- endif -%}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Søk",
  "tag": "section",
  "settings": []
}
{% endschema %}
