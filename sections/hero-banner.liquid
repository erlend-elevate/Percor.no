<section class="hero" aria-label="Hovedbanner">
  <div class="hero__bg">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 1920 }}"
        srcset="
          {{ section.settings.image | image_url: width: 768 }} 768w,
          {{ section.settings.image | image_url: width: 1200 }} 1200w,
          {{ section.settings.image | image_url: width: 1920 }} 1920w
        "
        sizes="100vw"
        alt="{{ section.settings.image.alt | default: 'Percor arbeidstøy og profilklær' }}"
        width="1920"
        height="700"
        loading="eager"
        fetchpriority="high"
      >
    {%- endif -%}
  </div>
  <div class="hero__overlay"></div>

  <div class="container hero__content">
    {%- if section.settings.heading != blank -%}
      <h1 class="hero__title">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="hero__subtitle">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="hero__actions">
      {%- if section.settings.button_text_1 != blank -%}
        <a href="{{ section.settings.button_link_1 }}" class="btn btn--primary btn--lg">
          {{ section.settings.button_text_1 }}
        </a>
      {%- endif -%}

      {%- if section.settings.button_text_2 != blank -%}
        <a href="{{ section.settings.button_link_2 }}" class="btn btn--secondary-light btn--lg">
          {{ section.settings.button_text_2 }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero-banner",
  "tag": "section",
  "class": "hero-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bakgrunnsbilde",
      "info": "Anbefalt: 1920x700px"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Alt du trenger av arbeidstøy og profilering — fra én leverandør"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Undertekst",
      "default": "Percor leverer arbeidstøy, profilklær, verneutstyr og trykk direkte fra europeiske kvalitetsprodusenter. Du får alt under ett tak."
    },
    {
      "type": "text",
      "id": "button_text_1",
      "label": "Knapp 1 tekst",
      "default": "Se våre produkter"
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Knapp 1 lenke",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "button_text_2",
      "label": "Knapp 2 tekst",
      "default": "Be om tilbud"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Knapp 2 lenke",
      "default": "/pages/kontakt"
    }
  ],
  "presets": [
    {
      "name": "Hero-banner"
    }
  ]
}
{% endschema %}
