<section class="section" aria-label="Aktuelt">
  <div class="container">
    <div class="section-header">
      <h2>{{ section.settings.heading | default: 'Aktuelt fra Percor' }}</h2>
    </div>

    {%- if blogs[section.settings.blog].articles.size > 0 -%}
      <div class="grid grid--3">
        {%- for article in blogs[section.settings.blog].articles limit: section.settings.posts_to_show -%}
          <article class="card">
            {%- if article.image -%}
              <a href="{{ article.url }}" class="card__image">
                <img
                  src="{{ article.image | image_url: width: 600 }}"
                  alt="{{ article.image.alt | default: article.title }}"
                  width="600"
                  height="400"
                  loading="lazy"
                >
              </a>
            {%- endif -%}
            <div class="card__body">
              <time class="text-light" style="font-size: 0.8125rem;" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                {{ article.published_at | date: '%d.%m.%Y' }}
              </time>
              <h3 class="card__title mt-sm">
                <a href="{{ article.url }}" style="color: inherit; text-decoration: none;">{{ article.title }}</a>
              </h3>
              <p class="card__text">{{ article.excerpt_or_content | strip_html | truncatewords: 20 }}</p>
              <a href="{{ article.url }}" class="card__link">Les mer</a>
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="grid grid--3">
        {%- for i in (1..3) -%}
          <article class="card">
            <div class="card__image" style="background: var(--color-bg-light);"></div>
            <div class="card__body">
              <time class="text-light" style="font-size: 0.8125rem;">{{ 'now' | date: '%d.%m.%Y' }}</time>
              <h3 class="card__title mt-sm">Blogginnlegg kommer snart</h3>
              <p class="card__text">Her kommer artikler om arbeidstøy, profilklær og tips for bedrifter.</p>
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.show_view_all -%}
      <div class="text-center mt-xl">
        <a href="{{ blogs[section.settings.blog].url }}" class="btn btn--secondary">Se alle innlegg</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Blogginnlegg",
  "tag": "section",
  "class": "blog-posts-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Aktuelt fra Percor"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Velg blogg",
      "default": "aktuelt"
    },
    {
      "type": "range",
      "id": "posts_to_show",
      "label": "Antall innlegg",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Vis 'Se alle'-knapp",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Blogginnlegg"
    }
  ]
}
{% endschema %}
