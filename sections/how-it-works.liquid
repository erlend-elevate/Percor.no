<section class="section section--bg-light" aria-label="Slik fungerer det">
  <div class="container">
    <div class="section-header">
      <h2>{{ section.settings.heading | default: 'Fra produkt til ferdig profilering — slik fungerer det' }}</h2>
    </div>

    <div class="steps">
      {%- for block in section.blocks -%}
        <div class="step" {{ block.shopify_attributes }}>
          <div class="step__number">{{ forloop.index }}</div>
          <h3 class="step__title">{{ block.settings.title }}</h3>
          <p class="step__text">{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_text != blank -%}
      <div class="text-center mt-2xl">
        <a href="{{ section.settings.cta_link }}" class="btn btn--primary">{{ section.settings.cta_text }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Slik fungerer det",
  "tag": "section",
  "class": "how-it-works-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Overskrift",
      "default": "Fra produkt til ferdig profilering — slik fungerer det"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA knapp tekst",
      "default": "Be om tilbud for bedriften din"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA lenke",
      "default": "/pages/kontakt"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Steg",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Tittel",
          "default": "Steg"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Beskrivelse",
          "default": "Kort beskrivelse av dette steget"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Slik fungerer det",
      "blocks": [
        { "type": "step", "settings": { "title": "Velg produkter", "text": "Finn det du trenger i nettbutikken" } },
        { "type": "step", "settings": { "title": "Send oss logo", "text": "Vi tar oss av design og oppsett" } },
        { "type": "step", "settings": { "title": "Vi sender korrektur", "text": "Du godkjenner før produksjon" } },
        { "type": "step", "settings": { "title": "Levering", "text": "Rett til døren eller hent i butikk" } }
      ]
    }
  ]
}
{% endschema %}
