{% render 'breadcrumbs' %}

<div class="container">
  <div class="page-header">
    <h1>{{ blog.title }}</h1>
  </div>

  <div class="grid grid--3" style="padding-bottom: var(--spacing-3xl);">
    {%- for article in blog.articles -%}
      <article class="card">
        {%- if article.image -%}
          <a href="{{ article.url }}" class="card__image">
            <img
              src="{{ article.image | image_url: width: 600 }}"
              alt="{{ article.image.alt | default: article.title }}"
              width="600"
              height="400"
              loading="lazy"
            >
          </a>
        {%- endif -%}
        <div class="card__body">
          <time class="text-light" style="font-size: 0.8125rem;" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
            {{ article.published_at | date: '%d.%m.%Y' }}
          </time>
          <h2 class="card__title mt-sm" style="font-size: 1.125rem;">
            <a href="{{ article.url }}" style="color: inherit; text-decoration: none;">{{ article.title }}</a>
          </h2>
          <p class="card__text">{{ article.excerpt_or_content | strip_html | truncatewords: 25 }}</p>
          <a href="{{ article.url }}" class="card__link">Les mer</a>
        </div>
      </article>
    {%- endfor -%}
  </div>

  {%- if blog.articles.size == 0 -%}
    <div class="text-center" style="padding: var(--spacing-3xl) 0;">
      <p>Ingen innlegg publisert ennå. Kom tilbake snart!</p>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Blogg",
  "tag": "section",
  "settings": []
}
{% endschema %}
